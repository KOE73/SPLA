<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SPLA.Plugins.OneC.Avalonia.Views.OneC.OneCGraphWindow"
        Width="1400"
        Height="900"
        MinWidth="900"
        MinHeight="600"
        Background="{DynamicResource AppBackgroundBrush}">
    <Grid RowDefinitions="Auto,Auto,*"
          RowSpacing="10"
          Margin="12">
        <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto"
              ColumnSpacing="8">
            <TextBlock x:Name="RootObjectText"
                       VerticalAlignment="Center"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextForegroundBrush}" />
            <ComboBox x:Name="ModeSelector"
                      Grid.Column="1"
                      MinWidth="150" />
            <ComboBox x:Name="DepthSelector"
                      Grid.Column="2"
                      MinWidth="90" />
            <ComboBox x:Name="LimitSelector"
                      Grid.Column="3"
                      MinWidth="100" />
            <Button x:Name="RebuildGraphButton"
                    Grid.Column="4"
                    Content="Rebuild"
                    Background="{DynamicResource AccentBrush}"
                    Foreground="White"
                    Padding="12,6"
                    CornerRadius="8" />
            <Button x:Name="ToggleWindowModeButton"
                    Grid.Column="5"
                    Content="Full Screen"
                    Background="{DynamicResource InputBackgroundBrush}"
                    Foreground="{DynamicResource TextForegroundBrush}"
                    BorderBrush="{DynamicResource PanelBorderBrush}"
                    BorderThickness="1"
                    Padding="12,6"
                    CornerRadius="8" />
        </Grid>

        <TextBlock x:Name="GraphSummaryText"
                   Grid.Row="1"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource SubTextForegroundBrush}" />

        <NativeWebView x:Name="GraphWebView"
                       Grid.Row="2" />
    </Grid>
</Window>

version: 1
name: SPLA
workspace: .
agent:
  mode: Agent
  instructions:
  - AGENTS.md
  custom_prompt: Test project for SPLA Roslyn plugin validation. Prefer Roslyn tools for C# compile checks and deterministic scripts. Keep generated artifacts inside the workspace.
llm:
  provider: lmstudio
  endpoint: http://127.0.0.1:1234/v1
  api_key: lm-studio
  model: ''
  temperature: 1.1
ui:
  theme: cream
  density: mini
permissions:
  read: allow
  write: allow
  shell: allow
  internet: allow
plugins:
  network:
    enabled: false
  onec:
    enabled: false
  onec_avalonia:
    enabled: true
  test:
    enabled: true
  browser:
    enabled: false
  network.skills:
    enabled: false
  roslyn:
    enabled: true
  sql:
    enabled: false
docs:
- docs/
ignore:
- bin/
- obj/
- .git/

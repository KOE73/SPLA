<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:SPLA.UI.Avalonia.ViewModels"
        xmlns:chat="clr-namespace:SPLA.UI.Avalonia.Views.Chat"
        xmlns:plugins="clr-namespace:SPLA.UI.Avalonia.Views.Plugins"
        xmlns:status="clr-namespace:SPLA.UI.Avalonia.Views.Status"
        xmlns:sidebar="clr-namespace:SPLA.UI.Avalonia.Views.Sidebar"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
        x:Class="SPLA.UI.Avalonia.MainWindow"
        x:Name="RootWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="SPLA - Local AI Assistant"
        Icon="avares://SPLA.UI.Avalonia/Assets/spla_icon.png"
        WindowDecorations="BorderOnly"
        ExtendClientAreaToDecorationsHint="True"
        Background="{DynamicResource AppBackgroundBrush}">

    <Window.Styles>
        <!-- Sidebar toggle accent override (base caption styles are in App.axaml) -->
        <Style Selector="Button.caption.sidebar:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#30007ACC"/>
        </Style>
        <Style Selector="Button.caption.sidebar:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="30,*" ColumnDefinitions="300,*,5,240" x:Name="RootGrid">

        <!-- ── Custom Title Bar ── -->
        <DockPanel Grid.Row="0" Grid.ColumnSpan="4"
                   Background="{DynamicResource TitleBarBackgroundBrush}">

            <!-- App name (left, non-interactive so drag works through it) -->
            <StackPanel DockPanel.Dock="Left"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="12,0,0,0"
                        IsHitTestVisible="False">
                <TextBlock Text="SPLA"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource SubTextForegroundBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Text="—"
                           FontSize="12"
                           Margin="8,0"
                           Foreground="{DynamicResource SubTextForegroundBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding ProjectFilePath}"
                           FontSize="12"
                           Foreground="{DynamicResource SubTextForegroundBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Window controls (right) -->
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <!-- Agent memory debug -->
                <Button Classes="caption"
                        Content="🧠"
                        Command="{Binding OpenKvDebugCommand}"
                        ToolTip.Tip="Agent Memory (KV Debug)"/>
                <!-- Real context debug -->
                <Button Classes="caption"
                        Content="📋"
                        Command="{Binding OpenContextDebugCommand}"
                        ToolTip.Tip="Real Context (last request)"/>
                <!-- System prompt preview -->
                <Button Classes="caption"
                        Content="📝"
                        Command="{Binding OpenPromptDebugCommand}"
                        ToolTip.Tip="System Prompt (live preview by source)"/>
                <!-- TEMP: schema-editor live debug (Фаза 1). Убрать после verify. -->
                <Button Classes="caption"
                        Content="🧩"
                        Click="OpenSchemaEditorDebug_Click"
                        ToolTip.Tip="Workspace Shell (live debug)"/>
                <!-- Thin client: web UI over an embedded service (preview). -->
                <Button Classes="caption"
                        Content="🌐"
                        Command="{Binding OpenThinClientCommand}"
                        ToolTip.Tip="Thin Client — web UI over embedded service (preview)"/>
                <!-- Sidebar toggle -->
                <Button Classes="caption sidebar"
                        Content="◧"
                        Command="{Binding ToggleSidebarCommand}"
                        ToolTip.Tip="Plugins &amp; Skills"/>
                <!-- Minimize -->
                <Button Classes="caption"
                        Content="─"
                        Click="MinimizeButton_Click"
                        ToolTip.Tip="Minimize"/>
                <!-- Maximize / Restore -->
                <Button Classes="caption"
                        Content="□"
                        Click="MaximizeButton_Click"
                        x:Name="MaximizeButton"
                        ToolTip.Tip="Maximize"/>
                <!-- Close -->
                <Button Classes="caption close"
                        Content="✕"
                        Click="CloseButton_Click"
                        ToolTip.Tip="Close"/>
            </StackPanel>

            <!-- Drag area (fills center, passes through to window drag) -->
            <Border Background="Transparent"
                    PointerPressed="TitleBar_PointerPressed"/>
        </DockPanel>

        <!-- ── Navigation Panel (left) ── -->
        <Grid Grid.Row="1" Grid.Column="0" RowDefinitions="*,Auto,Auto">
            <chat:ChatListView Grid.Row="0" DataContext="{Binding}" />
            <plugins:PluginCommandsView Grid.Row="1" DataContext="{Binding}" />
            <status:StatusView Grid.Row="2" DataContext="{Binding ActiveChat.Status}" SettingsRequested="StatusControl_SettingsRequested" />
        </Grid>

        <!-- ── Chat Area (active chat; background chats keep running unseen) ── -->
        <chat:ChatView Grid.Row="1" Grid.Column="1" DataContext="{Binding ActiveChat}" />

        <!-- ── Sidebar splitter (col 2) ── -->
        <GridSplitter Grid.Row="1" Grid.Column="2"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="{DynamicResource PanelBorderBrush}"
                      ResizeBehavior="PreviousAndNext"/>

        <!-- ── Right Sidebar (col 3) ── -->
        <sidebar:SidebarPanelView Grid.Row="1" Grid.Column="3"
                                   DataContext="{Binding Sidebar}"/>

    </Grid>
</Window>

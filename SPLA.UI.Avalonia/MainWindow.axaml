<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:web="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.WebView"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
        x:Class="SPLA.UI.Avalonia.MainWindow"
        x:Name="RootWindow"
        Title="SPLA - Local AI Assistant"
        Icon="avares://SPLA.UI.Avalonia/Assets/spla_icon.png"
        Width="1200" Height="820" MinWidth="640" MinHeight="420"
        WindowDecorations="BorderOnly"
        ExtendClientAreaToDecorationsHint="True"
        Background="{DynamicResource AppBackgroundBrush}">

    <!-- The window is a pure shell: Avalonia owns only the OS frame; the entire content is the web
         client (one renderer) over the shared embedded service. Debug/other panels open as separate
         SurfaceWindow frames (tear-off), each hosting a single web surface. -->
    <Grid RowDefinitions="30,*">

        <!-- ── Custom title bar (the only native chrome) ── -->
        <DockPanel Grid.Row="0" Background="{DynamicResource TitleBarBackgroundBrush}">
            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="12,0,0,0" IsHitTestVisible="False">
                <TextBlock Text="SPLA" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource SubTextForegroundBrush}" VerticalAlignment="Center"/>
                <TextBlock Text="—" FontSize="12" Margin="8,0"
                           Foreground="{DynamicResource SubTextForegroundBrush}" VerticalAlignment="Center"/>
                <TextBlock x:Name="TitleText" FontSize="12"
                           Foreground="{DynamicResource SubTextForegroundBrush}" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <!-- Debug as a tear-off web surface window -->
                <Button Classes="caption" Content="🧠" Click="OpenDebugSurface_Click"
                        ToolTip.Tip="Debug (memory / context / prompt) — opens as a separate window"/>
                <!-- Reload the web client -->
                <Button Classes="caption" Content="⟳" Click="Reload_Click" ToolTip.Tip="Reload web client"/>
                <Button Classes="caption" Content="─" Click="MinimizeButton_Click" ToolTip.Tip="Minimize"/>
                <Button Classes="caption" Content="□" Click="MaximizeButton_Click"
                        x:Name="MaximizeButton" ToolTip.Tip="Maximize"/>
                <Button Classes="caption close" Content="✕" Click="CloseButton_Click" ToolTip.Tip="Close"/>
            </StackPanel>

            <Border Background="Transparent" PointerPressed="TitleBar_PointerPressed"/>
        </DockPanel>

        <!-- ── The whole UI: web client ── -->
        <web:NativeWebView x:Name="Browser" Grid.Row="1"/>
    </Grid>
</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SPLA.UI.Avalonia.ConfirmDeleteChatWindow"
        Title="Delete chat"
        Width="360" Height="190"
        MinWidth="300"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        WindowDecorations="BorderOnly"
        ExtendClientAreaToDecorationsHint="True"
        Background="{DynamicResource AppBackgroundBrush}">

    <Window.Styles>
        <Style Selector="Button.action">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="Button.cancel">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource SubTextForegroundBrush}"/>
        </Style>
        <Style Selector="Button.cancel:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
        </Style>
        <Style Selector="Button.danger">
            <Setter Property="Background" Value="#C0392B"/>
            <Setter Property="BorderBrush" Value="#922B21"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.danger:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#E74C3C"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="30,*">

        <!-- Title bar (close only — no resize) -->
        <DockPanel Grid.Row="0" Background="{DynamicResource TitleBarBackgroundBrush}">
            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="12,0,0,0"
                        IsHitTestVisible="False">
                <TextBlock Text="Confirm"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource SubTextForegroundBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Classes="caption close" Content="✕" Click="TitleBarClose_Click"/>
            </StackPanel>
            <Border Background="Transparent" PointerPressed="TitleBar_PointerPressed"/>
        </DockPanel>

        <Grid Grid.Row="1" RowDefinitions="*,Auto" Margin="20,16,20,16">

        <StackPanel Grid.Row="0" Spacing="8" VerticalAlignment="Center">
            <TextBlock Text="Delete this chat?"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextForegroundBrush}"/>
            <TextBlock x:Name="ChatTitleBlock"
                       FontSize="12"
                       Foreground="{DynamicResource SubTextForegroundBrush}"
                       TextWrapping="Wrap"
                       MaxLines="2"
                       TextTrimming="CharacterEllipsis"/>
        </StackPanel>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
            <Button x:Name="CancelBtn" Classes="action cancel" Content="Cancel"/>
            <Button x:Name="DeleteBtn" Classes="action danger" Content="Delete"/>
        </StackPanel>

        </Grid>

    </Grid>
</Window>

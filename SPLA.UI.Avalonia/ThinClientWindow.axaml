<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:web="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.WebView"
        x:Class="SPLA.UI.Avalonia.ThinClientWindow"
        Title="SPLA — Thin Client (web)"
        Width="1100" Height="780" MinWidth="520" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        WindowDecorations="BorderOnly"
        ExtendClientAreaToDecorationsHint="True"
        Background="{DynamicResource AppBackgroundBrush}">

    <Grid RowDefinitions="30,*">
        <!-- Title bar -->
        <DockPanel Grid.Row="0" Background="{DynamicResource TitleBarBackgroundBrush}">
            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="12,0,0,0" IsHitTestVisible="False">
                <TextBlock Text="SPLA" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource SubTextForegroundBrush}" VerticalAlignment="Center"/>
                <TextBlock x:Name="StatusText" Text="— starting service…" FontSize="12" Margin="6,0,0,0"
                           Foreground="{DynamicResource SubTextForegroundBrush}" Opacity="0.6" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Classes="caption" Content="⟳" Click="ReloadButton_Click" ToolTip.Tip="Reload"/>
                <Button Classes="caption" Content="─" Click="MinimizeButton_Click"/>
                <Button Classes="caption" Content="□" Click="MaximizeButton_Click"/>
                <Button Classes="caption close" Content="✕" Click="CloseButton_Click"/>
            </StackPanel>
            <Border Background="Transparent" PointerPressed="TitleBar_PointerPressed"/>
        </DockPanel>

        <web:NativeWebView x:Name="Browser" Grid.Row="1"/>
    </Grid>
</Window>

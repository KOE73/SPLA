<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SPLA.UI.Avalonia.ViewModels.Settings"
             x:Class="SPLA.UI.Avalonia.Views.Settings.SettingsAppearanceView"
             x:DataType="vm:SettingsViewModel">
    <StackPanel Spacing="{DynamicResource StandardSpacing}">
        <TextBlock Text="Appearance" FontSize="{DynamicResource BaseFontSize}" FontWeight="Bold" Foreground="{DynamicResource TextForegroundBrush}"/>
        <Border Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="{DynamicResource StandardCornerRadius}" Padding="{DynamicResource StandardPadding}">
            <StackPanel Spacing="{DynamicResource StandardSpacing}">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Color Theme" Foreground="{DynamicResource TextForegroundBrush}" FontSize="{DynamicResource BaseFontSize}"/>
                        <TextBlock Text="Choose global UI color palette." Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="{DynamicResource SmallFontSize}"/>
                    </StackPanel>
                    <ComboBox Grid.Column="1" ItemsSource="{Binding AvailableThemes}" SelectedItem="{Binding Theme}" Width="150"
                              Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}"/>
                </Grid>
                <Border Height="1" Background="{DynamicResource PanelBorderBrush}" Margin="0,5"/>
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="UI Density" Foreground="{DynamicResource TextForegroundBrush}" FontSize="{DynamicResource BaseFontSize}"/>
                        <TextBlock Text="Controls margins, padding, and font sizes." Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="{DynamicResource SmallFontSize}"/>
                    </StackPanel>
                    <ComboBox Grid.Column="1" ItemsSource="{Binding AvailableDensities}" SelectedItem="{Binding Density}" Width="150"
                              Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}"/>
                </Grid>
            </StackPanel>
        </Border>

        <TextBlock Text="Prompt Retention Status" FontSize="{DynamicResource BaseFontSize}" FontWeight="Bold" Foreground="{DynamicResource TextForegroundBrush}" Margin="0,15,0,0"/>
        <Border Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="{DynamicResource StandardCornerRadius}" Padding="{DynamicResource StandardPadding}">
            <StackPanel Spacing="8">
                <TextBlock Text="Indicators showing how messages are retained in the model's request context:" Foreground="{DynamicResource TextForegroundBrush}" FontSize="{DynamicResource SmallFontSize}" FontWeight="Bold"/>
                
                <Grid ColumnDefinitions="30,*" Margin="0,2">
                    <Border Grid.Column="0" Width="18" Height="18" CornerRadius="9" Background="{DynamicResource PanelBorderBrush}" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="📌" FontSize="10" Foreground="{DynamicResource TextForegroundBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <TextBlock Text="Always send (Persistent)" Foreground="{DynamicResource TextForegroundBrush}" FontSize="{DynamicResource SmallFontSize}" FontWeight="Bold"/>
                        <TextBlock Text="The message is permanently included in all subsequent requests to the model." Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="11" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
                
                <Grid ColumnDefinitions="30,*" Margin="0,2">
                    <Border Grid.Column="0" Width="18" Height="18" CornerRadius="9" Background="{DynamicResource PanelBorderBrush}" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="🔄" FontSize="10" Foreground="{DynamicResource TextForegroundBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <TextBlock Text="Until superseded (Auto)" Foreground="{DynamicResource TextForegroundBrush}" FontSize="{DynamicResource SmallFontSize}" FontWeight="Bold"/>
                        <TextBlock Text="The message is sent until a newer version of the same item replaces it (e.g. dynamic context)." Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="11" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>

                <Grid ColumnDefinitions="30,*" Margin="0,2">
                    <Border Grid.Column="0" Width="18" Height="18" CornerRadius="9" Background="{DynamicResource PanelBorderBrush}" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="➡️" FontSize="10" Foreground="{DynamicResource TextForegroundBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <TextBlock Text="Next request only (One-time)" Foreground="{DynamicResource TextForegroundBrush}" FontSize="{DynamicResource SmallFontSize}" FontWeight="Bold"/>
                        <TextBlock Text="The message is sent only in the very next request and is then excluded." Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="11" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>

                <Grid ColumnDefinitions="30,*" Margin="0,2">
                    <Border Grid.Column="0" Width="18" Height="18" CornerRadius="9" Background="{DynamicResource PanelBorderBrush}" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="❌" FontSize="10" Foreground="{DynamicResource TextForegroundBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <TextBlock Text="Do not send (Never)" Foreground="{DynamicResource TextForegroundBrush}" FontSize="{DynamicResource SmallFontSize}" FontWeight="Bold"/>
                        <TextBlock Text="The message is completely excluded from model requests." Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="11" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>

                <Grid ColumnDefinitions="30,*" Margin="0,2">
                    <Border Grid.Column="0" Width="18" Height="18" CornerRadius="9" Background="{DynamicResource PanelBorderBrush}" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="🛑" FontSize="10" Foreground="{DynamicResource TextForegroundBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <TextBlock Text="Until resolved (Blocked)" Foreground="{DynamicResource TextForegroundBrush}" FontSize="{DynamicResource SmallFontSize}" FontWeight="Bold"/>
                        <TextBlock Text="The message is sent repeatedly until the related task, error, or permission request is resolved." Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="11" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>

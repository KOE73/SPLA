<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SPLA.UI.Avalonia.ViewModels.Settings"
             x:Class="SPLA.UI.Avalonia.Views.Settings.SettingsUsageView"
             x:DataType="vm:SettingsViewModel">
    <UserControl.Resources>
        <x:Double x:Key="NumFont">22</x:Double>
    </UserControl.Resources>
    <StackPanel Spacing="{DynamicResource StandardSpacing}">
        <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="Token Usage" FontSize="{DynamicResource BaseFontSize}" FontWeight="Bold"
                       Foreground="{DynamicResource TextForegroundBrush}" VerticalAlignment="Center"/>
            <Button Content="↻ Refresh" Command="{Binding RefreshTokenUsageCommand}"
                    FontSize="{DynamicResource SmallFontSize}" Padding="8,2"/>
        </StackPanel>
        <TextBlock Text="Real tokens reported by the provider, accumulated for every turn — successful or not."
                   Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="{DynamicResource SmallFontSize}"
                   TextWrapping="Wrap"/>

        <!-- SESSION -->
        <Border Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="1" CornerRadius="{DynamicResource StandardCornerRadius}" Padding="{DynamicResource StandardPadding}">
            <StackPanel Spacing="6">
                <TextBlock Text="This session" FontWeight="Bold" Foreground="{DynamicResource TextForegroundBrush}" FontSize="{DynamicResource BaseFontSize}"/>
                <TextBlock Text="{Binding UsageSessionTotal, StringFormat='{}{0:N0} tokens total'}"
                           FontSize="{DynamicResource NumFont}" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                <ProgressBar Minimum="0" Maximum="1" Value="{Binding UsageSessionPromptFraction}" Height="8"/>
                <StackPanel Orientation="Horizontal" Spacing="16">
                    <TextBlock Text="{Binding UsageSessionPrompt, StringFormat='input: {0:N0}'}" Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="{DynamicResource BaseFontSize}"/>
                    <TextBlock Text="{Binding UsageSessionCompletion, StringFormat='output: {0:N0}'}" Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="{DynamicResource BaseFontSize}"/>
                    <TextBlock Text="{Binding UsageSessionTurns, StringFormat='turns: {0:N0}'}" Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="{DynamicResource BaseFontSize}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- PROJECT -->
        <Border Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="1" CornerRadius="{DynamicResource StandardCornerRadius}" Padding="{DynamicResource StandardPadding}">
            <StackPanel Spacing="6">
                <TextBlock Text="This project (lifetime)" FontWeight="Bold" Foreground="{DynamicResource TextForegroundBrush}" FontSize="{DynamicResource BaseFontSize}"/>
                <TextBlock Text="{Binding UsageProjectTotal, StringFormat='{}{0:N0} tokens total'}"
                           FontSize="{DynamicResource NumFont}" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                <ProgressBar Minimum="0" Maximum="1" Value="{Binding UsageProjectPromptFraction}" Height="8"/>
                <StackPanel Orientation="Horizontal" Spacing="16">
                    <TextBlock Text="{Binding UsageProjectPrompt, StringFormat='input: {0:N0}'}" Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="{DynamicResource BaseFontSize}"/>
                    <TextBlock Text="{Binding UsageProjectCompletion, StringFormat='output: {0:N0}'}" Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="{DynamicResource BaseFontSize}"/>
                    <TextBlock Text="{Binding UsageProjectTurns, StringFormat='turns: {0:N0}'}" Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="{DynamicResource BaseFontSize}"/>
                </StackPanel>
                <TextBlock Text="Stored in &lt;workspace&gt;/.spla/token-usage.json" Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="{DynamicResource SmallFontSize}" Opacity="0.7"/>
            </StackPanel>
        </Border>

        <!-- GLOBAL -->
        <Border Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="1" CornerRadius="{DynamicResource StandardCornerRadius}" Padding="{DynamicResource StandardPadding}">
            <StackPanel Spacing="6">
                <TextBlock Text="This machine (all projects, lifetime)" FontWeight="Bold" Foreground="{DynamicResource TextForegroundBrush}" FontSize="{DynamicResource BaseFontSize}"/>
                <TextBlock Text="{Binding UsageGlobalTotal, StringFormat='{}{0:N0} tokens total'}"
                           FontSize="{DynamicResource NumFont}" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                <ProgressBar Minimum="0" Maximum="1" Value="{Binding UsageGlobalPromptFraction}" Height="8"/>
                <StackPanel Orientation="Horizontal" Spacing="16">
                    <TextBlock Text="{Binding UsageGlobalPrompt, StringFormat='input: {0:N0}'}" Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="{DynamicResource BaseFontSize}"/>
                    <TextBlock Text="{Binding UsageGlobalCompletion, StringFormat='output: {0:N0}'}" Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="{DynamicResource BaseFontSize}"/>
                    <TextBlock Text="{Binding UsageGlobalTurns, StringFormat='turns: {0:N0}'}" Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="{DynamicResource BaseFontSize}"/>
                </StackPanel>
                <TextBlock Text="Stored in ~/.spla/token-usage.json" Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="{DynamicResource SmallFontSize}" Opacity="0.7"/>
            </StackPanel>
        </Border>

        <TextBlock Text="The bar shows the input/output split (filled = input share)."
                   Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="{DynamicResource SmallFontSize}" TextWrapping="Wrap"/>
    </StackPanel>
</UserControl>

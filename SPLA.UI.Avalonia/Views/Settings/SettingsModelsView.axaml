<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SPLA.UI.Avalonia.ViewModels.Settings"
             xmlns:models="using:SPLA.Domain.Models"
             x:Class="SPLA.UI.Avalonia.Views.Settings.SettingsModelsView"
             x:DataType="vm:SettingsViewModel">
    <StackPanel Spacing="{DynamicResource StandardSpacing}">
        <TextBlock Text="Server — LM Studio" FontSize="{DynamicResource BaseFontSize}" FontWeight="Bold" Foreground="{DynamicResource TextForegroundBrush}"/>
        <TextBlock Text="Browse available models, their capabilities, and load/unload them in memory. Dialogue itself always uses the OpenAI-compatible /v1 endpoint (see LLM Provider)."
                   Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="{DynamicResource SmallFontSize}" TextWrapping="Wrap"/>
        <Border Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="{DynamicResource StandardCornerRadius}" Padding="{DynamicResource StandardPadding}">
            <StackPanel Spacing="{DynamicResource StandardSpacing}">
                <Grid ColumnDefinitions="*,Auto">
                    <Button Grid.Column="0" Content="🔍 Scan provider" Command="{Binding FetchModelsCommand}"
                            Background="{DynamicResource AccentBrush}" Foreground="White"
                            CornerRadius="{DynamicResource StandardCornerRadius}" HorizontalAlignment="Left"/>
                    <TextBlock Grid.Column="1" Text="{Binding ModelDetails.Count, StringFormat='{}{0} models'}"
                               Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="{DynamicResource SmallFontSize}"
                               VerticalAlignment="Center"/>
                </Grid>
                <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="{DynamicResource SmallFontSize}" TextWrapping="Wrap"/>

                <!-- Capability table -->
                <Border BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="{DynamicResource StandardCornerRadius}"
                        IsVisible="{Binding HasModelDetails}">
                    <StackPanel>
                        <!-- Header -->
                        <Grid ColumnDefinitions="*,60,82,56,36,36,44,56,88" Background="{DynamicResource MessageBackgroundBrush}" Margin="0">
                            <Grid.Styles>
                                <Style Selector="TextBlock">
                                    <Setter Property="FontSize" Value="{DynamicResource SmallFontSize}"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextForegroundBrush}"/>
                                    <Setter Property="Padding" Value="6,5"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </Grid.Styles>
                            <TextBlock Grid.Column="0" Text="Model"/>
                            <TextBlock Grid.Column="1" Text="Params"/>
                            <TextBlock Grid.Column="2" Text="Quant"/>
                            <TextBlock Grid.Column="3" Text="Context"/>
                            <TextBlock Grid.Column="4" Text="🖼️" ToolTip.Tip="Vision / images" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="5" Text="🔨" ToolTip.Tip="Tool / function calling" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="6" Text="🧠" ToolTip.Tip="Reasoning / thinking" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="7" Text="State"/>
                            <TextBlock Grid.Column="8" Text=""/>
                        </Grid>

                        <ItemsControl ItemsSource="{Binding ModelDetails}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="models:ModelInfo">
                                    <Grid ColumnDefinitions="*,60,82,56,36,36,44,56,88">
                                        <Grid.Styles>
                                            <Style Selector="TextBlock">
                                                <Setter Property="FontSize" Value="{DynamicResource SmallFontSize}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource SubTextForegroundBrush}"/>
                                                <Setter Property="Padding" Value="6,4"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                            <Style Selector="Border.row">
                                                <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}"/>
                                                <Setter Property="BorderThickness" Value="0,1,0,0"/>
                                            </Style>
                                            <Style Selector="Button.act">
                                                <Setter Property="FontSize" Value="{DynamicResource SmallFontSize}"/>
                                                <Setter Property="Padding" Value="6,2"/>
                                                <Setter Property="Margin" Value="4,2"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                            </Style>
                                        </Grid.Styles>
                                        <Border Grid.Column="0" Grid.ColumnSpan="9" Classes="row"/>
                                        <TextBlock Grid.Column="0" Text="{Binding Id}" Foreground="{DynamicResource TextForegroundBrush}"
                                                   TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding Id}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding ParamsDisplay}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding QuantDisplay}"/>
                                        <TextBlock Grid.Column="3" Text="{Binding ContextDisplay}"/>
                                        <TextBlock Grid.Column="4" Text="{Binding VisionFlag}" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="5" Text="{Binding ToolsFlag}" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="6" Text="{Binding ReasoningFlag}" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="7" Text="{Binding StateDisplay}"
                                                   Foreground="{DynamicResource AccentBrush}"/>
                                        <Button Grid.Column="8" Classes="act" Content="Load"
                                                IsVisible="{Binding !IsLoaded}"
                                                Command="{Binding $parent[ItemsControl].((vm:SettingsViewModel)DataContext).LoadModelCommand}"
                                                CommandParameter="{Binding}"
                                                Background="{DynamicResource AccentBrush}" Foreground="White"/>
                                        <Button Grid.Column="8" Classes="act" Content="Unload"
                                                IsVisible="{Binding IsLoaded}"
                                                Command="{Binding $parent[ItemsControl].((vm:SettingsViewModel)DataContext).UnloadModelCommand}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent" Foreground="{DynamicResource TextForegroundBrush}"
                                                BorderBrush="{DynamicResource PanelBorderBrush}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <TextBlock Text="Capabilities come from the LM Studio native API (/api/v1/models). Other OpenAI-compatible providers only expose model ids."
                           Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="{DynamicResource SmallFontSize}" TextWrapping="Wrap"/>

                <TextBlock Text="Select the active model from the dropdown in the chat bar. Reasoning depth is controlled from the 🧠 selector next to Temperature."
                           Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="{DynamicResource SmallFontSize}" TextWrapping="Wrap" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>

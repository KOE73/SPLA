<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SPLA.UI.Avalonia.ViewModels.Settings"
             x:Class="SPLA.UI.Avalonia.Views.Settings.SettingsPluginsView"
             x:DataType="vm:SettingsViewModel">
    <StackPanel Spacing="{DynamicResource StandardSpacing}">
        <TextBlock Text="Installed Plugins" FontSize="{DynamicResource BaseFontSize}" FontWeight="Bold" Foreground="{DynamicResource TextForegroundBrush}"/>
        <TextBlock Text="Manage active plugins, dependencies, and custom prompts." Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="{DynamicResource BaseFontSize}" TextWrapping="Wrap" Margin="0,-5,0,5"/>

        <ItemsControl ItemsSource="{Binding PluginsSettings}">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:PluginSettingViewModel">
                    <StackPanel Spacing="{DynamicResource StandardSpacing}">
                        <Border Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="{DynamicResource StandardCornerRadius}" Padding="{DynamicResource StandardPadding}" Margin="0,0,0,10">
                            <StackPanel Spacing="{DynamicResource StandardSpacing}">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <ToggleSwitch IsChecked="{Binding Enabled}" OnContent="Enabled" OffContent="Disabled"/>
                                    <TextBlock Text="{Binding Id}" FontWeight="Bold" FontSize="{DynamicResource BaseFontSize}" VerticalAlignment="Center" Foreground="{DynamicResource TextForegroundBrush}"/>
                                    <TextBlock Text="{Binding Type}" FontSize="{DynamicResource SmallFontSize}" VerticalAlignment="Center" Foreground="{DynamicResource SubTextForegroundBrush}"/>
                                </StackPanel>
                                <TextBlock Text="{Binding EffectiveStateDisplay}" Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="{DynamicResource SmallFontSize}" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding DependsOn, StringFormat='Depends on: {0}'}" Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="{DynamicResource SmallFontSize}" TextWrapping="Wrap" IsVisible="{Binding DependsOn, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                <TextBlock Text="Custom Prompt (optional)" Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="12"/>
                                <TextBox Text="{Binding CustomPrompt}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60" Background="{DynamicResource SurfaceBackgroundBrush}" Foreground="{DynamicResource TextForegroundBrush}" BorderBrush="{DynamicResource PanelBorderBrush}"/>

                                <!-- Plugin settings hint: the editor lives on its own page under Plugins -->
                                <TextBlock Text="⚙ This plugin has a dedicated settings page (see the menu under Plugins)."
                                           IsVisible="{Binding HasEditor}"
                                           Foreground="{DynamicResource SubTextForegroundBrush}"
                                           FontSize="{DynamicResource SmallFontSize}" FontStyle="Italic"
                                           TextWrapping="Wrap" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <ItemsControl ItemsSource="{Binding Children}" IsVisible="{Binding HasChildren}" Margin="24,0,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:PluginSettingViewModel">
                                    <Border Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="{DynamicResource StandardCornerRadius}" Padding="{DynamicResource StandardPadding}" Margin="0,0,0,10">
                                        <StackPanel Spacing="{DynamicResource StandardSpacing}">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <TextBlock Text="└" Foreground="{DynamicResource SubTextForegroundBrush}" VerticalAlignment="Center"/>
                                                <ToggleSwitch IsChecked="{Binding Enabled}" OnContent="Enabled" OffContent="Disabled"/>
                                                <TextBlock Text="{Binding Id}" FontWeight="Bold" FontSize="{DynamicResource BaseFontSize}" VerticalAlignment="Center" Foreground="{DynamicResource TextForegroundBrush}"/>
                                                <TextBlock Text="{Binding Type}" FontSize="{DynamicResource SmallFontSize}" VerticalAlignment="Center" Foreground="{DynamicResource SubTextForegroundBrush}"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding EffectiveStateDisplay}" Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="{DynamicResource SmallFontSize}" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding DependsOn, StringFormat='Depends on: {0}'}" Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="{DynamicResource SmallFontSize}" TextWrapping="Wrap" IsVisible="{Binding DependsOn, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                            <TextBlock Text="Custom Prompt (optional)" Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="12"/>
                                            <TextBox Text="{Binding CustomPrompt}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60" Background="{DynamicResource SurfaceBackgroundBrush}" Foreground="{DynamicResource TextForegroundBrush}" BorderBrush="{DynamicResource PanelBorderBrush}"/>

                                            <TextBlock Text="⚙ This plugin has a dedicated settings page (see the menu under Plugins)."
                                                       IsVisible="{Binding HasEditor}"
                                                       Foreground="{DynamicResource SubTextForegroundBrush}"
                                                       FontSize="{DynamicResource SmallFontSize}" FontStyle="Italic"
                                                       TextWrapping="Wrap" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <TextBlock IsVisible="{Binding !PluginsSettings.Count}" Text="No plugins found in the 'plugins' directory." Foreground="{DynamicResource SubTextForegroundBrush}" FontStyle="Italic"/>
    </StackPanel>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SPLA.UI.Avalonia.ViewModels.Settings"
             x:Class="SPLA.UI.Avalonia.Views.Settings.SettingsPermissionsView"
             x:DataType="vm:SettingsViewModel">
    <StackPanel Spacing="{DynamicResource StandardSpacing}">
        <TextBlock Text="Local Permissions" FontSize="{DynamicResource BaseFontSize}" FontWeight="Bold" Foreground="{DynamicResource TextForegroundBrush}"/>
        <TextBlock Text="Inherits from global mode matrix. Future updates will allow precise overrides here." Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="{DynamicResource SmallFontSize}" Margin="0,0,0,10"/>
        <Border Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="{DynamicResource StandardCornerRadius}">
            <StackPanel>
                <Grid ColumnDefinitions="*,Auto" Margin="{DynamicResource StandardPadding}">
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="File Access Rules" Foreground="{DynamicResource TextForegroundBrush}" FontSize="{DynamicResource BaseFontSize}"/>
                        <TextBlock Text="Configure allowed and denied paths." Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="{DynamicResource SmallFontSize}"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="Open" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" IsEnabled="False"/>
                </Grid>
                <Border Height="1" Background="{DynamicResource PanelBorderBrush}"/>
                <Grid ColumnDefinitions="*,Auto" Margin="{DynamicResource StandardPadding}">
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Terminal Commands" Foreground="{DynamicResource TextForegroundBrush}" FontSize="{DynamicResource BaseFontSize}"/>
                        <TextBlock Text="Configure allowed execution commands." Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="{DynamicResource SmallFontSize}"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="Open" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" IsEnabled="False"/>
                </Grid>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>

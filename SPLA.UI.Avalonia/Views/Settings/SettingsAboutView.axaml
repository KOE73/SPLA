<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SPLA.UI.Avalonia.ViewModels.Settings"
             x:Class="SPLA.UI.Avalonia.Views.Settings.SettingsAboutView"
             x:DataType="vm:SettingsViewModel">
    <StackPanel Spacing="{DynamicResource StandardSpacing}">
        <TextBlock Text="About SPLA" FontSize="{DynamicResource BaseFontSize}" FontWeight="Bold" Foreground="{DynamicResource TextForegroundBrush}"/>
        <Border Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="{DynamicResource StandardCornerRadius}" Padding="{DynamicResource StandardPadding}">
            <StackPanel Spacing="{DynamicResource StandardSpacing}">
                <SelectableTextBlock Text="What is SPLA?" FontSize="{DynamicResource BaseFontSize}" FontWeight="Bold" Foreground="{DynamicResource TextForegroundBrush}"/>
                <SelectableTextBlock Text="SPLA (Secure Project Local Assistant) is a local AI assistant designed to run on your machine, leveraging local LLMs (like LM Studio) to interact securely with your codebase. It provides tool access to read, inspect, edit files, and execute terminal commands under strict permission rules." Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="{DynamicResource BaseFontSize}" TextWrapping="Wrap"/>
                
                <Border Height="1" Background="{DynamicResource PanelBorderBrush}" Margin="0,5"/>
                
                <SelectableTextBlock Text="The Project Concept (.spla)" FontSize="{DynamicResource BaseFontSize}" FontWeight="Bold" Foreground="{DynamicResource TextForegroundBrush}"/>
                <SelectableTextBlock Text="SPLA operates on a project basis. A project is defined by a 'spla.spla' file in the root directory. This configuration file cascades down and specifies:&#x0a;• Workspace directory paths&#x0a;• Security preset modes (Chat, Research, Inspect, Edit, Agent)&#x0a;• Permission rules (e.g., allowed or denied paths and shell commands)&#x0a;• Context files and instructions (like AGENTS.md)" Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="{DynamicResource BaseFontSize}" TextWrapping="Wrap"/>

                <Border Height="1" Background="{DynamicResource PanelBorderBrush}" Margin="0,5"/>

                <SelectableTextBlock Text="How It Works" FontSize="{DynamicResource BaseFontSize}" FontWeight="Bold" Foreground="{DynamicResource TextForegroundBrush}"/>
                <SelectableTextBlock Text="When you open a project or a folder, SPLA reads its '.spla' configuration. It initializes the assistant and equips it with tools according to the chosen mode. When the assistant performs actions (like reading a file or running a terminal command), SPLA checks the project permissions. If a command or path is not pre-approved, the UI prompts you to Allow once, Allow &amp; remember, or Deny the request, ensuring complete control over what the AI does on your local machine." Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="{DynamicResource BaseFontSize}" TextWrapping="Wrap"/>

                <Border Height="1" Background="{DynamicResource PanelBorderBrush}" Margin="0,5"/>

                <SelectableTextBlock Text="Version Info" FontSize="{DynamicResource BaseFontSize}" FontWeight="Bold" Foreground="{DynamicResource TextForegroundBrush}"/>
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <SelectableTextBlock Text="Build Time:" Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="{DynamicResource BaseFontSize}"/>
                    <SelectableTextBlock Text="{Binding BuildTime}" Foreground="{DynamicResource TextForegroundBrush}" FontSize="{DynamicResource BaseFontSize}" FontWeight="SemiBold"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>

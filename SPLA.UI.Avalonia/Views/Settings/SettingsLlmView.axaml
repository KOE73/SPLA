<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SPLA.UI.Avalonia.ViewModels.Settings"
             x:Class="SPLA.UI.Avalonia.Views.Settings.SettingsLlmView"
             x:DataType="vm:SettingsViewModel">
    <StackPanel Spacing="{DynamicResource StandardSpacing}">
        <TextBlock Text="LLM Connection" FontSize="{DynamicResource BaseFontSize}" FontWeight="Bold" Foreground="{DynamicResource TextForegroundBrush}"/>
        <Border Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="{DynamicResource StandardCornerRadius}" Padding="{DynamicResource StandardPadding}">
            <StackPanel Spacing="{DynamicResource StandardSpacing}">
                <TextBlock Text="LMStudio API Endpoint:" Foreground="{DynamicResource TextForegroundBrush}" FontSize="{DynamicResource BaseFontSize}"/>
                <TextBox Text="{Binding BaseUrl}" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" Foreground="{DynamicResource TextForegroundBrush}"/>
                <TextBlock Text="API Key:" Foreground="{DynamicResource TextForegroundBrush}" FontSize="{DynamicResource BaseFontSize}" Margin="0,10,0,0"/>
                <TextBox Text="{Binding ApiKey}" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" Foreground="{DynamicResource TextForegroundBrush}"/>
                <Border Height="1" Background="{DynamicResource PanelBorderBrush}" Margin="0,5"/>
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="{DynamicResource StandardSpacing}">
                    <StackPanel Grid.Column="0" Grid.Row="0">
                        <TextBlock Text="Temperature" Foreground="{DynamicResource TextForegroundBrush}" FontSize="{DynamicResource BaseFontSize}"/>
                        <TextBlock Text="Controls response variability for the next model calls." Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="{DynamicResource SmallFontSize}"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Grid.Row="0" Text="{Binding Temperature, StringFormat='{}{0:0.0}'}"
                               Foreground="{DynamicResource TextForegroundBrush}" FontSize="{DynamicResource BaseFontSize}"
                               Width="40" TextAlignment="Right" VerticalAlignment="Center"/>
                    <Slider Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1"
                            Minimum="0" Maximum="2" TickFrequency="0.1" IsSnapToTickEnabled="True"
                            Value="{Binding Temperature}" Margin="0,8,0,0"/>
                    <Grid Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="2"
                          ColumnDefinitions="110,*"
                          RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                          Margin="0,8,0,0">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Range" Foreground="{DynamicResource TextForegroundBrush}" FontSize="{DynamicResource BaseFontSize}" FontWeight="Bold"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Use" Foreground="{DynamicResource TextForegroundBrush}" FontSize="{DynamicResource BaseFontSize}" FontWeight="Bold"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="0.0-0.2" Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="{DynamicResource BaseFontSize}" Margin="0,4,12,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="Code, tool calls, fixes, compact." Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="{DynamicResource BaseFontSize}" TextWrapping="Wrap" Margin="0,4,0,0"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="0.3-0.5" Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="{DynamicResource BaseFontSize}" Margin="0,4,12,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="Normal agent work." Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="{DynamicResource BaseFontSize}" TextWrapping="Wrap" Margin="0,4,0,0"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="0.6-0.9" Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="{DynamicResource BaseFontSize}" Margin="0,4,12,0"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="Architecture discussion and option search." Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="{DynamicResource BaseFontSize}" TextWrapping="Wrap" Margin="0,4,0,0"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="1.0" Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="{DynamicResource BaseFontSize}" Margin="0,4,12,0"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="More flexible." Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="{DynamicResource BaseFontSize}" TextWrapping="Wrap" Margin="0,4,0,0"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="1.1" Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="{DynamicResource BaseFontSize}" Margin="0,4,12,0"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="Brainstorming." Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="{DynamicResource BaseFontSize}" TextWrapping="Wrap" Margin="0,4,0,0"/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="1.3+" Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="{DynamicResource BaseFontSize}" Margin="0,4,12,0"/>
                        <TextBlock Grid.Row="6" Grid.Column="1" Text="Often noisy." Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="{DynamicResource BaseFontSize}" TextWrapping="Wrap" Margin="0,4,0,0"/>

                        <TextBlock Grid.Row="7" Grid.Column="0" Text="2.0" Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="{DynamicResource BaseFontSize}" Margin="0,4,12,0"/>
                        <TextBlock Grid.Row="7" Grid.Column="1" Text="Experiment, not daily work." Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="{DynamicResource BaseFontSize}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </Grid>
                </Grid>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>

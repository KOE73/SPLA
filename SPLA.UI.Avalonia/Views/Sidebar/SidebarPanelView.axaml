<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SPLA.UI.Avalonia.ViewModels.Sidebar"
             x:Class="SPLA.UI.Avalonia.Views.Sidebar.SidebarPanelView"
             x:DataType="vm:SidebarPanelViewModel">

    <UserControl.Styles>

        <!-- TreeViewItem: compact, stretch -->
        <Style Selector="TreeViewItem">
            <Setter Property="Padding" Value="2,2,6,2"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>

        <!-- IsExpanded bound to node VM -->
        <Style Selector="TreeViewItem" x:DataType="vm:SidebarNodeViewModel">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
        </Style>

        <!-- Kill selection highlight — toggle panel, not a list -->
        <Style Selector="TreeViewItem:selected /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="TreeViewItem:selected:focus /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="TreeViewItem:pointerover /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="{DynamicResource PanelBorderBrush}"/>
        </Style>

        <!-- Compact ToggleSwitch: no text labels -->
        <Style Selector="ToggleSwitch.sidebar">
            <Setter Property="OnContent" Value=""/>
            <Setter Property="OffContent" Value=""/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Filter TextBox -->
        <Style Selector="TextBox.sidebar-filter">
            <Setter Property="FontSize" Value="{DynamicResource SidebarNodeFontSize}"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Expand/Collapse toolbar button -->
        <Style Selector="Button.sidebar-toolbar">
            <Setter Property="FontSize" Value="{DynamicResource SidebarNodeFontSize}"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Foreground" Value="{DynamicResource SubTextForegroundBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.sidebar-toolbar:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource PanelBorderBrush}"/>
        </Style>

    </UserControl.Styles>

    <Border Background="{DynamicResource PanelBackgroundBrush}"
            BorderBrush="{DynamicResource PanelBorderBrush}"
            BorderThickness="1,0,0,0">
        <DockPanel>

            <!-- Header -->
            <Border DockPanel.Dock="Top"
                    Padding="8,5"
                    Background="{DynamicResource PanelBackgroundBrush}"
                    BorderBrush="{DynamicResource PanelBorderBrush}"
                    BorderThickness="0,0,0,1">
                <TextBlock Text="PLUGINS &amp; SKILLS"
                           FontSize="{DynamicResource SidebarNodeFontSize}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource SubTextForegroundBrush}"/>
            </Border>

            <!-- Toolbar: filter + expand/collapse -->
            <Border DockPanel.Dock="Top"
                    Padding="6,4"
                    BorderBrush="{DynamicResource PanelBorderBrush}"
                    BorderThickness="0,0,0,1">
                <DockPanel LastChildFill="True">

                    <!-- Expand / Collapse buttons -->
                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                Spacing="2"
                                Margin="4,0,0,0">
                        <Button Classes="sidebar-toolbar"
                                Command="{Binding ExpandAllCommand}"
                                ToolTip.Tip="Expand all"
                                Content="⊞"/>
                        <Button Classes="sidebar-toolbar"
                                Command="{Binding CollapseAllCommand}"
                                ToolTip.Tip="Collapse all"
                                Content="⊟"/>
                    </StackPanel>

                    <!-- Filter box -->
                    <TextBox Classes="sidebar-filter"
                             Text="{Binding FilterText}"
                             PlaceholderText="Filter…"/>

                </DockPanel>
            </Border>

            <!-- Tree -->
            <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                <TreeView ItemsSource="{Binding FilteredNodes}"
                          Background="Transparent"
                          BorderThickness="0"
                          Padding="2,2,2,2">
                    <TreeView.DataTemplates>
                        <TreeDataTemplate x:DataType="vm:SidebarNodeViewModel"
                                          ItemsSource="{Binding Children}">

                            <!-- Row: [icon + label  ···] [preload toggle] [enable toggle] -->
                            <Grid ColumnDefinitions="*,Auto,Auto"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Center">

                                <!-- Left: icon + label -->
                                <StackPanel Grid.Column="0"
                                            Orientation="Horizontal"
                                            Spacing="4"
                                            VerticalAlignment="Center">

                                    <!-- Tool/Skill kind icon -->
                                    <TextBlock Text="{Binding KindIcon}"
                                               IsVisible="{Binding IsLeaf}"
                                               FontSize="{DynamicResource SidebarIconFontSize}"
                                               Foreground="{DynamicResource SubTextForegroundBrush}"
                                               VerticalAlignment="Center"/>

                                    <!-- Plugin header — bold -->
                                    <TextBlock Text="{Binding Label}"
                                               IsVisible="{Binding IsPlugin}"
                                               FontSize="{DynamicResource SidebarNodeFontSize}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextForegroundBrush}"
                                               VerticalAlignment="Center"/>

                                    <!-- Tool / Skill leaf -->
                                    <TextBlock Text="{Binding Label}"
                                               IsVisible="{Binding IsLeaf}"
                                               FontSize="{DynamicResource SidebarNodeFontSize}"
                                               Foreground="{DynamicResource SubTextForegroundBrush}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip.Tip="{Binding Description}"/>
                                </StackPanel>

                                <!-- Preload toggle (skills only) -->
                                <LayoutTransformControl Grid.Column="1"
                                                        IsVisible="{Binding IsSkill}"
                                                        Margin="8,0,0,0"
                                                        VerticalAlignment="Center"
                                                        ToolTip.Tip="Preload into context">
                                    <LayoutTransformControl.LayoutTransform>
                                        <ScaleTransform ScaleX="{DynamicResource SidebarToggleScale}"
                                                        ScaleY="{DynamicResource SidebarToggleScale}"/>
                                    </LayoutTransformControl.LayoutTransform>
                                    <ToggleSwitch IsChecked="{Binding IsPreloaded}"
                                                  Classes="sidebar"/>
                                </LayoutTransformControl>

                                <!-- Enabled toggle -->
                                <LayoutTransformControl Grid.Column="2"
                                                        Margin="4,0,0,0"
                                                        VerticalAlignment="Center"
                                                        ToolTip.Tip="Enable">
                                    <LayoutTransformControl.LayoutTransform>
                                        <ScaleTransform ScaleX="{DynamicResource SidebarToggleScale}"
                                                        ScaleY="{DynamicResource SidebarToggleScale}"/>
                                    </LayoutTransformControl.LayoutTransform>
                                    <ToggleSwitch IsChecked="{Binding IsEnabled}"
                                                  Classes="sidebar"/>
                                </LayoutTransformControl>

                            </Grid>

                        </TreeDataTemplate>
                    </TreeView.DataTemplates>
                </TreeView>
            </ScrollViewer>

        </DockPanel>
    </Border>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SPLA.UI.Avalonia.ViewModels"
             x:Class="SPLA.UI.Avalonia.Views.Plugins.PluginCommandsView"
             x:DataType="vm:MainWindowViewModel">
    <Border BorderBrush="{DynamicResource PanelBorderBrush}"
            BorderThickness="0,1,0,0"
            Background="{DynamicResource PanelBackgroundBrush}"
            Padding="{DynamicResource StandardMargin}">
        <StackPanel Spacing="{DynamicResource StandardSpacing}">
            <TextBlock Text="Plugin commands"
                       Foreground="{DynamicResource TextForegroundBrush}"
                       FontSize="{DynamicResource HeaderFontSize}"
                       FontWeight="Bold" />
            <ItemsControl ItemsSource="{Binding PluginUiCommands}"
                          IsVisible="{Binding HasPluginUiCommands}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" ItemSpacing="{DynamicResource StandardSpacing}" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Content="{Binding DisplayName}"
                                Command="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).ExecutePluginUiCommandCommand}"
                                CommandParameter="{Binding}"
                                Background="{DynamicResource AccentBrush}"
                                Foreground="White"
                                FontWeight="SemiBold"
                                Padding="10,6"
                                CornerRadius="{DynamicResource StandardCornerRadius}"
                                ToolTip.Tip="{Binding Description}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>
</UserControl>

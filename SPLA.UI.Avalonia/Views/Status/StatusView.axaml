<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SPLA.UI.Avalonia.ViewModels.Status"
             x:Class="SPLA.UI.Avalonia.Views.Status.StatusView"
             x:DataType="vm:StatusViewModel"
             Background="{DynamicResource PanelBackgroundBrush}"
             Padding="10">
    <Grid ColumnDefinitions="Auto,*" RowDefinitions="*,Auto">
        <StackPanel Grid.Column="1" Grid.RowSpan="2" Orientation="Vertical" Spacing="4" VerticalAlignment="Center" HorizontalAlignment="Right">
            <TextBlock Text="{Binding Endpoint}" Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="10" TextAlignment="Right" />
            <TextBlock Text="{Binding ModelName}" Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="10" TextAlignment="Right" />
            <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                <TextBlock Text="{Binding ActiveOperation}" Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="10" />
                <TextBlock Text="{Binding ActiveElapsedSeconds, StringFormat='{}{0}s'}" Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="10" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                <TextBlock Text="{Binding CurrentPromptTokens, StringFormat='P: {0}'}" Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="10" />
                <TextBlock Text="{Binding CurrentCompletionTokens, StringFormat='C: {0}'}" Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="10" />
            </StackPanel>
        </StackPanel>
        
        <Button Grid.Column="0" Grid.Row="1" Content="⚙️" FontSize="20" Background="Transparent" Foreground="{DynamicResource TextForegroundBrush}"
                Click="SettingsButton_Click" Cursor="Hand" VerticalAlignment="Bottom" HorizontalAlignment="Left" BorderThickness="0" Padding="0" Margin="0,10,10,0"/>
    </Grid>
</UserControl>

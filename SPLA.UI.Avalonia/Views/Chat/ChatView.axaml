<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:chatvm="using:SPLA.UI.Avalonia.ViewModels.Chat"
             xmlns:chat="clr-namespace:SPLA.UI.Avalonia.Views.Chat"
             x:Class="SPLA.UI.Avalonia.Views.Chat.ChatView"
             x:DataType="chatvm:ChatSessionViewModel">

    <Border Margin="{DynamicResource StandardMargin}"
            Background="{DynamicResource AppBackgroundBrush}"
            BorderBrush="{DynamicResource PanelBorderBrush}"
            BorderThickness="1"
            CornerRadius="{DynamicResource StandardCornerRadius}"
            ClipToBounds="True">
        <Grid RowDefinitions="*,Auto,Auto">

            <Grid Grid.Row="0">
                <chat:ChatNativeView DataContext="{Binding}"
                                     IsVisible="{Binding IsNativeChatViewSelected}" />
                <chat:ChatWebView DataContext="{Binding}"
                                  IsVisible="{Binding IsWebChatViewSelected}" />
                <!-- Clarify overlay: floats at the bottom of the message area while agent awaits answer -->
                <chat:ClarifyView DataContext="{Binding ActiveClarify}"
                                   IsVisible="{Binding $parent[UserControl].((chatvm:ChatSessionViewModel)DataContext).HasActiveClarify}"
                                   VerticalAlignment="Bottom" />
            </Grid>

            <!-- Divider between conversation and composer -->
            <Border Grid.Row="1" Height="1"
                    Background="{DynamicResource PanelBorderBrush}"
                    Margin="{DynamicResource StandardMargin}" />

            <chat:ChatInputView Grid.Row="2" DataContext="{Binding}" />
        </Grid>
    </Border>
</UserControl>

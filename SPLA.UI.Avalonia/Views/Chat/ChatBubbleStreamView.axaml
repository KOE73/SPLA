<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SPLA.UI.Avalonia.ViewModels"
             xmlns:msg="using:SPLA.UI.Avalonia.ViewModels.Messages"
             xmlns:md="clr-namespace:Markdown.Avalonia;assembly=Markdown.Avalonia"
             x:Class="SPLA.UI.Avalonia.Views.Chat.ChatBubbleStreamView"
             x:DataType="vm:MainWindowViewModel">
    
    <ScrollViewer x:Name="ChatScrollViewer" 
                  Margin="{DynamicResource StandardMargin}"
                  HorizontalScrollBarVisibility="Disabled">
        <ItemsControl ItemsSource="{Binding Messages}">
            <ItemsControl.DataTemplates>
                <!-- Template for PermissionMessageViewModel -->
                <DataTemplate DataType="msg:PermissionMessageViewModel">
                    <Border Margin="{DynamicResource CompactMargin}" Padding="{DynamicResource StandardPadding}" CornerRadius="{DynamicResource StandardCornerRadius}" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1">
                        <StackPanel Spacing="{DynamicResource StandardSpacing}">
                             <TextBlock Text="⚠️ Permission Required" FontSize="{DynamicResource BaseFontSize}" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" />
                            <SelectableTextBlock Text="{Binding Content}" TextWrapping="Wrap" Foreground="{DynamicResource TextForegroundBrush}" FontSize="{DynamicResource BaseFontSize}" />
                            <SelectableTextBlock Text="{Binding Arguments}" TextWrapping="Wrap" Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="{DynamicResource SmallFontSize}" FontFamily="Consolas" />
                            
                            <StackPanel Orientation="Horizontal" Spacing="{DynamicResource StandardSpacing}" Margin="0,5,0,0" IsVisible="{Binding !IsAnswered}">
                                <Button Content="Allow &amp; remember" Command="{Binding AllowRememberCommand}" Background="#2E7D32" Foreground="White" Cursor="Hand" FontSize="{DynamicResource BaseFontSize}" Padding="{DynamicResource CompactMargin}"/>
                                <Button Content="Allow once" Command="{Binding AllowOnceCommand}" Background="{DynamicResource AccentBrush}" Foreground="White" Cursor="Hand" FontSize="{DynamicResource BaseFontSize}" Padding="{DynamicResource CompactMargin}"/>
                                <Button Content="Deny" Command="{Binding DenyCommand}" Background="#C62828" Foreground="White" Cursor="Hand" FontSize="{DynamicResource BaseFontSize}" Padding="{DynamicResource CompactMargin}"/>
                            </StackPanel>
                            <TextBlock Text="Decision made." IsVisible="{Binding IsAnswered}" Foreground="{DynamicResource SubTextForegroundBrush}" FontStyle="Italic" FontSize="{DynamicResource SmallFontSize}" />
                        </StackPanel>
                    </Border>
                </DataTemplate>

                <!-- Template for standard messages in Bubble Mode -->
                <DataTemplate DataType="msg:MessageViewModel">
                    <StackPanel Classes="msg-root bubble"
                                Classes.user="{Binding IsUser}"
                                Classes.ai="{Binding IsAssistant}"
                                IsVisible="{Binding IsVisibleMessage}">
                        
                        <StackPanel.Styles>
                            <Style Selector="StackPanel.msg-root.bubble">
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                            </Style>
                            
                            <Style Selector="Border.bubble">
                                <Setter Property="Margin" Value="{DynamicResource ChatBubbleMargin}"/>
                                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                            </Style>
                            
                            <Style Selector="Border.bubble.user">
                                <Setter Property="Background" Value="{DynamicResource UserBubbleBackgroundBrush}"/>
                                <Setter Property="CornerRadius" Value="12"/>
                                <Setter Property="Padding" Value="{DynamicResource StandardPadding}"/>
                                <Setter Property="Margin" Value="{DynamicResource UserChatBubbleMargin}"/>
                            </Style>
                            
                            <Style Selector="Border.bubble.ai">
                                <Setter Property="Background" Value="{DynamicResource AiBubbleBackgroundBrush}"/>
                                <Setter Property="CornerRadius" Value="12"/>
                                <Setter Property="Padding" Value="{DynamicResource StandardPadding}"/>
                                <Setter Property="Margin" Value="{DynamicResource AiChatBubbleMargin}"/>
                            </Style>

                            <Style Selector="Border.bubble.tool-call">
                                <Setter Property="Padding" Value="{DynamicResource CompactMargin}"/>
                                <Setter Property="Margin" Value="{DynamicResource ChatBubbleMargin}"/>
                                <Setter Property="Opacity" Value="0.75"/>
                            </Style>
                        </StackPanel.Styles>

                        <!-- The bubble container -->
                        <Border Classes="bubble"
                                Classes.user="{Binding IsUser}"
                                Classes.ai="{Binding IsAssistant}"
                                Classes.tool="{Binding IsTool}"
                                Classes.error="{Binding IsError}"
                                Classes.tool-call="{Binding IsToolCallNotice}">
                            <Border.Styles>
                                <Style Selector="Border">
                                    <Setter Property="Background" Value="{DynamicResource MessageBackgroundBrush}"/>
                                    <Setter Property="Padding" Value="{DynamicResource StandardPadding}"/>
                                    <Setter Property="CornerRadius" Value="{DynamicResource StandardCornerRadius}"/>
                                </Style>
                                <Style Selector="Border.tool">
                                    <Setter Property="Opacity" Value="0.9"/>
                                </Style>
                                <Style Selector="Border.error">
                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                </Style>
                            </Border.Styles>
                            
                            <StackPanel>
                                <!-- Role is hidden in bubble mode because colors distinguish user/ai, 
                                     but system/tool messages still show their type if needed. -->
                                <SelectableTextBlock Text="{Binding Role}" 
                                                     IsVisible="{Binding IsSystemOrTool}"
                                                     FontSize="{DynamicResource SmallFontSize}" FontWeight="Bold" Margin="0,0,0,2">
                                    <SelectableTextBlock.Styles>
                                        <Style Selector="SelectableTextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                        </Style>
                                    </SelectableTextBlock.Styles>
                                </SelectableTextBlock>
                                
                                <md:MarkdownScrollViewer Markdown="{Binding Content}"
                                                         SelectionEnabled="True"
                                                         Margin="0,0,0,4"
                                                         IsVisible="{Binding IsMarkdown}" />
                                <SelectableTextBlock Text="{Binding Content}"
                                                     TextWrapping="Wrap"
                                                     Foreground="{DynamicResource TextForegroundBrush}"
                                                     Margin="0,0,0,4"
                                                     IsVisible="{Binding IsPlainText}" />
                                
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,2,0,0">
                                    <!-- Retention Policy Indicator -->
                                    <Button Classes="RetentionBtn" Width="18" Height="18" CornerRadius="9" 
                                            Background="{DynamicResource PanelBorderBrush}"
                                            ToolTip.Tip="{Binding RetentionDescription}"
                                            VerticalAlignment="Center">
                                        <Button.Styles>
                                            <Style Selector="Button.RetentionBtn">
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Padding" Value="0"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                            </Style>
                                        </Button.Styles>
                                        <TextBlock Text="{Binding RetentionIcon}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextForegroundBrush}"/>
                                        <Button.Flyout>
                                            <MenuFlyout Placement="Bottom">
                                                <MenuItem Header="Always send (📌)" Command="{Binding SetRetentionCommand}" CommandParameter="Persistent"/>
                                                <MenuItem Header="Until superseded (🔄)" Command="{Binding SetRetentionCommand}" CommandParameter="UntilSuperseded"/>
                                                <MenuItem Header="Next step only (➡️)" Command="{Binding SetRetentionCommand}" CommandParameter="NextStepOnly"/>
                                                <MenuItem Header="Do not send (❌)" Command="{Binding SetRetentionCommand}" CommandParameter="Never"/>
                                                <MenuItem Header="Until resolved (🛑)" Command="{Binding SetRetentionCommand}" CommandParameter="UntilResolved"/>
                                            </MenuFlyout>
                                        </Button.Flyout>
                                    </Button>

                                    <Button Content="Delete"
                                            Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).DeleteMessageCommand}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent" Foreground="{DynamicResource SubTextForegroundBrush}"
                                            FontSize="{DynamicResource SmallFontSize}" Padding="2" Cursor="Hand" />
                                    <Button Content="📋 Copy" Command="{Binding CopyCommand}" 
                                            Background="Transparent" Foreground="{DynamicResource SubTextForegroundBrush}"
                                            FontSize="{DynamicResource SmallFontSize}" Padding="2" Cursor="Hand" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.DataTemplates>
        </ItemsControl>
    </ScrollViewer>
</UserControl>

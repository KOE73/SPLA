<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SPLA.UI.Avalonia.ViewModels"
             xmlns:msg="using:SPLA.UI.Avalonia.ViewModels.Messages"
             x:Class="SPLA.UI.Avalonia.Views.Chat.ChatDiagnosticView"
             x:DataType="vm:MainWindowViewModel">
    
    <ScrollViewer x:Name="ChatScrollViewer" 
                  Margin="2"
                  HorizontalScrollBarVisibility="Disabled">
        <ItemsControl ItemsSource="{Binding Messages}">
            <ItemsControl.DataTemplates>
                <!-- Template for PermissionMessageViewModel -->
                <DataTemplate DataType="msg:PermissionMessageViewModel">
                    <Border Margin="1" Padding="4" CornerRadius="2" Background="#2E1A1A" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1">
                        <StackPanel Spacing="2">
                            <TextBlock Text="⚠️ Permission Required" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" />
                            <SelectableTextBlock Text="{Binding Content}" TextWrapping="Wrap" Foreground="{DynamicResource TextForegroundBrush}" FontSize="10" FontFamily="Consolas" />
                            <SelectableTextBlock Text="{Binding Arguments}" TextWrapping="Wrap" Foreground="{DynamicResource SubTextForegroundBrush}" FontSize="9" FontFamily="Consolas" />
                            
                            <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,2,0,0" IsVisible="{Binding !IsAnswered}">
                                <Button Content="Allow &amp; remember" Command="{Binding AllowRememberCommand}" Background="#2E7D32" Foreground="White" Cursor="Hand" FontSize="9" Padding="4,2"/>
                                <Button Content="Allow once" Command="{Binding AllowOnceCommand}" Background="{DynamicResource AccentBrush}" Foreground="White" Cursor="Hand" FontSize="9" Padding="4,2"/>
                                <Button Content="Deny" Command="{Binding DenyCommand}" Background="#C62828" Foreground="White" Cursor="Hand" FontSize="9" Padding="4,2"/>
                            </StackPanel>
                            <TextBlock Text="Decision made." IsVisible="{Binding IsAnswered}" Foreground="{DynamicResource SubTextForegroundBrush}" FontStyle="Italic" FontSize="9" />
                        </StackPanel>
                    </Border>
                </DataTemplate>

                <!-- Template for standard messages (Diagnostic View) -->
                <DataTemplate DataType="msg:MessageViewModel">
                    <Border Classes="diag-msg"
                            Classes.user="{Binding IsUser}"
                            Classes.ai="{Binding IsAssistant}"
                            Classes.system="{Binding IsSystem}"
                            Classes.tool="{Binding IsTool}"
                            Classes.error="{Binding IsError}"
                            BorderBrush="{DynamicResource PanelBorderBrush}" 
                            BorderThickness="0,0,0,1" 
                            Padding="4,2" 
                            Margin="0,1">
                        <Border.Styles>
                            <Style Selector="Border.diag-msg">
                                <Setter Property="Background" Value="{DynamicResource MessageBackgroundBrush}"/>
                            </Style>
                            <Style Selector="Border.diag-msg.user">
                                <Setter Property="Background" Value="{DynamicResource UserBubbleBackgroundBrush}"/>
                            </Style>
                            <Style Selector="Border.diag-msg.ai">
                                <Setter Property="Background" Value="{DynamicResource AiBubbleBackgroundBrush}"/>
                            </Style>
                            <Style Selector="Border.diag-msg.system">
                                <Setter Property="Background" Value="{DynamicResource SystemBubbleBackgroundBrush}"/>
                            </Style>
                            <Style Selector="Border.diag-msg.tool">
                                <Setter Property="Background" Value="{DynamicResource ToolBubbleBackgroundBrush}"/>
                            </Style>
                            <Style Selector="Border.diag-msg.error">
                                <Setter Property="Background" Value="{DynamicResource ErrorBubbleBackgroundBrush}"/>
                            </Style>
                        </Border.Styles>
                        <Grid RowDefinitions="Auto,*" ColumnDefinitions="*,Auto">
                            <!-- Metadata row -->
                            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <!-- Role label with customized background/foreground -->
                                <Border Padding="4,1" CornerRadius="2" Background="{DynamicResource PanelBackgroundBrush}">
                                    <TextBlock Text="{Binding Role}" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                                </Border>
                                
                                <!-- Context Retention Circle -->
                                <Button Classes="RetentionBtn" Width="14" Height="14" CornerRadius="7" 
                                        Background="{DynamicResource PanelBorderBrush}"
                                        ToolTip.Tip="{Binding RetentionDescription}"
                                        VerticalAlignment="Center">
                                    <Button.Styles>
                                        <Style Selector="Button.RetentionBtn">
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                        </Style>
                                    </Button.Styles>
                                    <TextBlock Text="{Binding RetentionIcon}" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource TextForegroundBrush}"/>
                                    <Button.Flyout>
                                        <MenuFlyout Placement="Bottom">
                                            <MenuItem Header="Always send (📌)" Command="{Binding SetRetentionCommand}" CommandParameter="Persistent"/>
                                            <MenuItem Header="Until superseded (🔄)" Command="{Binding SetRetentionCommand}" CommandParameter="UntilSuperseded"/>
                                            <MenuItem Header="Next step only (➡️)" Command="{Binding SetRetentionCommand}" CommandParameter="NextStepOnly"/>
                                            <MenuItem Header="Do not send (❌)" Command="{Binding SetRetentionCommand}" CommandParameter="Never"/>
                                            <MenuItem Header="Until resolved (🛑)" Command="{Binding SetRetentionCommand}" CommandParameter="UntilResolved"/>
                                        </MenuFlyout>
                                    </Button.Flyout>
                                </Button>
                                
                                <!-- ToolCallId details -->
                                <TextBlock Text="{Binding ToolCallId, StringFormat='[Id: {0}]'}" 
                                           IsVisible="{Binding ToolCallId, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                           FontSize="9" Foreground="{DynamicResource SubTextForegroundBrush}" VerticalAlignment="Center" FontFamily="Consolas"/>

                                <!-- ReplacementKey details -->
                                <TextBlock Text="{Binding ReplacementKey, StringFormat='[Key: {0}]'}" 
                                           IsVisible="{Binding ReplacementKey, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                           FontSize="9" Foreground="{DynamicResource SubTextForegroundBrush}" VerticalAlignment="Center" FontFamily="Consolas"/>
                            </StackPanel>

                            <!-- Actions -->
                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <Button Content="Del"
                                        Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).DeleteMessageCommand}"
                                        CommandParameter="{Binding}"
                                        Background="Transparent" BorderThickness="0" Foreground="{DynamicResource SubTextForegroundBrush}"
                                        FontSize="9" Padding="2,1" Cursor="Hand" />
                                <Button Content="Copy" Command="{Binding CopyCommand}" 
                                        Background="Transparent" BorderThickness="0" Foreground="{DynamicResource SubTextForegroundBrush}"
                                        FontSize="9" Padding="2,1" Cursor="Hand" />
                            </StackPanel>

                            <!-- Message Content / Details -->
                            <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="4,3,0,1">
                                <!-- Plain Text content for diagnostic view (monospace, tight line height) -->
                                <SelectableTextBlock Text="{Binding Content}"
                                                     TextWrapping="Wrap"
                                                     FontFamily="Consolas, Cascadia Code, monospace"
                                                     FontSize="10.5"
                                                     LineHeight="13"
                                                     Foreground="{DynamicResource TextForegroundBrush}" />
                                
                                <!-- Tool Calls details inside the view model, if any -->
                                <ItemsControl ItemsSource="{Binding ToolCalls}" Margin="12,2,0,0" IsVisible="{Binding ToolCalls, Converter={x:Static ObjectConverters.IsNotNull}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1,0,0,0" Padding="6,1" Margin="0,2" Background="{DynamicResource PanelBackgroundBrush}">
                                                <StackPanel Orientation="Vertical" Spacing="2" Margin="2,0,0,0">
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <TextBlock Text="🔧 Tool Call:" FontSize="9" Foreground="#FF8C00" FontWeight="Bold" FontFamily="Consolas"/>
                                                        <TextBlock Text="{Binding Function.Name}" FontSize="9" Foreground="{DynamicResource TextForegroundBrush}" FontWeight="Bold" FontFamily="Consolas"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Function.Arguments}" FontSize="9" Foreground="{DynamicResource SubTextForegroundBrush}" FontFamily="Consolas" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.DataTemplates>
        </ItemsControl>
    </ScrollViewer>
</UserControl>

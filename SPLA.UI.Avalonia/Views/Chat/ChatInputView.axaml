<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SPLA.UI.Avalonia.ViewModels"
             x:Class="SPLA.UI.Avalonia.Views.Chat.ChatInputView"
             x:DataType="vm:MainWindowViewModel">
    
    <StackPanel Margin="{DynamicResource StandardMargin}" Spacing="5">
        <!-- Input Area. Send/Stop are pinned to the editor's single-line height (InputBaseHeight)
             so they match the empty editor and don't grow as the editor expands. -->
        <Grid ColumnDefinitions="*,Auto">
            <TextBox x:Name="InputTextBox" Grid.Column="0" Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Enter message... (/compact)"
                     AcceptsReturn="True" MinHeight="{DynamicResource InputBaseHeight}" MaxHeight="100" TextWrapping="Wrap" FontSize="{DynamicResource BaseFontSize}"
                     Background="{DynamicResource InputBackgroundBrush}" Foreground="{DynamicResource TextForegroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" CornerRadius="{DynamicResource StandardCornerRadius}"
                     VerticalAlignment="Bottom" />
            <Button Grid.Column="1" Content="Send" Command="{Binding SendCommand}" FontSize="{DynamicResource BaseFontSize}"
                    Background="{DynamicResource AccentBrush}" Foreground="White" CornerRadius="{DynamicResource StandardCornerRadius}"
                    Height="{DynamicResource InputBaseHeight}" Padding="16,0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                    VerticalAlignment="Bottom" Margin="5,0,0,0"
                    IsVisible="{Binding IsNotBusy}" />
            <Button Grid.Column="1" Content="Stop" Command="{Binding StopCommand}" FontSize="{DynamicResource BaseFontSize}"
                    Background="#C62828" Foreground="White" CornerRadius="{DynamicResource StandardCornerRadius}"
                    Height="{DynamicResource InputBaseHeight}" Padding="16,0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                    VerticalAlignment="Bottom" Margin="5,0,0,0"
                    IsVisible="{Binding IsBusy}" />
        </Grid>

        <!-- Bottom Bar: Mode Selection & Chat Actions.
             A WrapPanel so groups reflow onto new lines when the window narrows instead of overlapping. -->
        <WrapPanel Orientation="Horizontal" Margin="0,5,0,0">
            <WrapPanel.Styles>
                <!-- Uniform gap between groups; bottom gap shows when rows wrap. -->
                <Style Selector="WrapPanel > :is(Control)">
                    <Setter Property="Margin" Value="0,3,16,3"/>
                    <Setter Property="VerticalAlignment" Value="Center"/>
                </Style>
            </WrapPanel.Styles>

                <ComboBox ItemsSource="{Binding Status.AvailableModeDescriptions}" SelectedItem="{Binding Status.SelectedModeDescription}"
                          Background="Transparent" BorderThickness="0" Foreground="{DynamicResource SubTextForegroundBrush}"
                          FontSize="{DynamicResource SmallFontSize}" VerticalAlignment="Center" />

                    <!-- Reasoning depth: toggle (off/on) or effort (low/medium/high), per the selected model -->
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center"
                                IsVisible="{Binding Settings.SelectedModelSupportsReasoning}">
                        <TextBlock Text="🧠" FontSize="{DynamicResource SmallFontSize}" VerticalAlignment="Center"
                                   ToolTip.Tip="Model reasoning depth" />
                        <ComboBox ItemsSource="{Binding Settings.SelectedModelReasoningOptions}"
                                  SelectedItem="{Binding Settings.ReasoningLevel}"
                                  MinWidth="80" Background="Transparent" BorderThickness="1"
                                  BorderBrush="{DynamicResource PanelBorderBrush}"
                                  Foreground="{DynamicResource SubTextForegroundBrush}"
                                  FontSize="{DynamicResource SmallFontSize}" VerticalAlignment="Center"
                                  ToolTip.Tip="off/on or reasoning effort (low/medium/high)" />
                    </StackPanel>

                    <!-- Temperature group -->
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <TextBlock Text="Temp" Foreground="{DynamicResource SubTextForegroundBrush}"
                                   FontSize="{DynamicResource SmallFontSize}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Settings.Temperature, StringFormat='{}{0:0.0}'}"
                                   Foreground="{DynamicResource SubTextForegroundBrush}"
                                   FontSize="{DynamicResource SmallFontSize}" Width="28"
                                   TextAlignment="Right" VerticalAlignment="Center" />
                        <Grid RowDefinitions="18,10" Width="260" Height="28" VerticalAlignment="Center">
                            <Slider Grid.Row="0" Minimum="0" Maximum="2" TickFrequency="0.1" IsSnapToTickEnabled="True"
                                    Value="{Binding Settings.Temperature}"
                                    Height="18" VerticalAlignment="Center"
                                    Margin="4,0" />
                            <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*,*" Margin="4,0">
                                <TextBlock Grid.Column="0" Text="Precise Code" Foreground="{DynamicResource SubTextForegroundBrush}"
                                           FontSize="8" VerticalAlignment="Top" />
                                <TextBlock Grid.Column="1" Text="Agent" Foreground="{DynamicResource SubTextForegroundBrush}"
                                           FontSize="8" TextAlignment="Center" VerticalAlignment="Top" />
                                <TextBlock Grid.Column="2" Text="Explore" Foreground="{DynamicResource SubTextForegroundBrush}"
                                           FontSize="8" TextAlignment="Center" VerticalAlignment="Top" />
                                <TextBlock Grid.Column="3" Text="Brainstorm" Foreground="{DynamicResource SubTextForegroundBrush}"
                                           FontSize="8" TextAlignment="Center" VerticalAlignment="Top" />
                                <TextBlock Grid.Column="4" Text="Experimental" Foreground="{DynamicResource SubTextForegroundBrush}"
                                           FontSize="8" TextAlignment="Right" VerticalAlignment="Top" />
                            </Grid>
                        </Grid>
                    </StackPanel>

                    <!-- Render mode selector: Native | Web -->
                    <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                        <StackPanel.Styles>
                            <Style Selector="Button.RenderModeBtn">
                                <Setter Property="Padding" Value="8,3"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}"/>
                                <Setter Property="CornerRadius" Value="4"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="MinHeight" Value="22"/>
                                <Setter Property="Foreground" Value="{DynamicResource SubTextForegroundBrush}"/>
                                <Setter Property="FontSize" Value="{DynamicResource SmallFontSize}"/>
                            </Style>
                            <Style Selector="Button.RenderModeBtn.selected">
                                <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Style>
                        </StackPanel.Styles>
                        <Button Classes="RenderModeBtn"
                                Classes.selected="{Binding IsNativeChatViewSelected}"
                                Content="Native"
                                Command="{Binding SelectRenderModeCommand}"
                                CommandParameter="native" />
                        <Button Classes="RenderModeBtn"
                                Classes.selected="{Binding IsWebChatViewSelected}"
                                Content="Web"
                                Command="{Binding SelectRenderModeCommand}"
                                CommandParameter="web" />
                    </StackPanel>

                    <!-- Display profile selector: data-driven from AvailableProfiles -->
                    <ItemsControl ItemsSource="{Binding AvailableProfiles}" VerticalAlignment="Center">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="2" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Classes="ProfileBtn"
                                        Classes.selected="{Binding IsSelected}"
                                        Content="{Binding DisplayName}"
                                        Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).SelectProfileCommand}"
                                        CommandParameter="{Binding}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        <ItemsControl.Styles>
                            <Style Selector="Button.ProfileBtn">
                                <Setter Property="Padding" Value="8,3"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}"/>
                                <Setter Property="CornerRadius" Value="4"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="MinHeight" Value="22"/>
                                <Setter Property="Foreground" Value="{DynamicResource SubTextForegroundBrush}"/>
                                <Setter Property="FontSize" Value="{DynamicResource SmallFontSize}"/>
                            </Style>
                            <Style Selector="Button.ProfileBtn.selected">
                                <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Style>
                        </ItemsControl.Styles>
                    </ItemsControl>

                    <!-- Chat actions -->
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <Button Content="Compact" Command="{Binding CompactContextCommand}" Background="Transparent" Foreground="{DynamicResource SubTextForegroundBrush}" Cursor="Hand" ToolTip.Tip="Create summary and compact context" FontSize="{DynamicResource SmallFontSize}" Padding="{DynamicResource CompactMargin}" />
                        <Button Content="⎇ Fork" Command="{Binding ForkChatCommand}" Background="Transparent" Foreground="{DynamicResource SubTextForegroundBrush}" Cursor="Hand" ToolTip.Tip="Duplicate Chat" FontSize="{DynamicResource SmallFontSize}" Padding="{DynamicResource CompactMargin}" />
                    </StackPanel>
        </WrapPanel>
    </StackPanel>
</UserControl>

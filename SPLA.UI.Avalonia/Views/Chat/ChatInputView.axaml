<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:chatvm="using:SPLA.UI.Avalonia.ViewModels.Chat"
             x:Class="SPLA.UI.Avalonia.Views.Chat.ChatInputView"
             x:DataType="chatvm:ChatSessionViewModel">
    
    <StackPanel Margin="{DynamicResource StandardMargin}" Spacing="5">
        <!-- Input Area. Send/Stop are pinned to the editor's single-line height (InputBaseHeight)
             so they match the empty editor and don't grow as the editor expands. -->
        <Grid ColumnDefinitions="*,Auto,Auto">
            <TextBox x:Name="InputTextBox" Grid.Column="0" Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Enter message... (/compact)"
                     AcceptsReturn="True" MinHeight="{DynamicResource InputBaseHeight}" MaxHeight="100" TextWrapping="Wrap" FontSize="{DynamicResource BaseFontSize}"
                     Background="{DynamicResource InputBackgroundBrush}" Foreground="{DynamicResource TextForegroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" CornerRadius="{DynamicResource StandardCornerRadius}"
                     VerticalAlignment="Bottom" />
            <Button Grid.Column="1" Command="{Binding Status.UnloadSkillCommand}"
                    IsVisible="{Binding Status.HasActiveSkill}"
                    Background="{DynamicResource InputBackgroundBrush}"
                    BorderBrush="{DynamicResource AccentBrush}"
                    Foreground="{DynamicResource TextForegroundBrush}"
                    CornerRadius="{DynamicResource StandardCornerRadius}"
                    Height="{DynamicResource InputBaseHeight}" Padding="10,0"
                    VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                    VerticalAlignment="Bottom" Margin="5,0,0,0"
                    ToolTip.Tip="{Binding Status.ActiveSkillId}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="Unload" FontSize="{DynamicResource BaseFontSize}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Status.ActiveSkillId}"
                               FontSize="{DynamicResource BaseFontSize}"
                               FontWeight="SemiBold"
                               MaxWidth="220"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Button>
            <Button Grid.Column="2" Content="Send" Command="{Binding SendCommand}" FontSize="{DynamicResource BaseFontSize}"
                    Background="{DynamicResource AccentBrush}" Foreground="White" CornerRadius="{DynamicResource StandardCornerRadius}"
                    Height="{DynamicResource InputBaseHeight}" Padding="16,0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                    VerticalAlignment="Bottom" Margin="5,0,0,0"
                    IsVisible="{Binding IsNotBusy}" />
            <Button Grid.Column="2" Content="Stop" Command="{Binding StopCommand}" FontSize="{DynamicResource BaseFontSize}"
                    Background="#C62828" Foreground="White" CornerRadius="{DynamicResource StandardCornerRadius}"
                    Height="{DynamicResource InputBaseHeight}" Padding="16,0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                    VerticalAlignment="Bottom" Margin="5,0,0,0"
                    IsVisible="{Binding IsBusy}" />
        </Grid>

        <!-- Bottom Bar: Mode Selection & Chat Actions.
             A WrapPanel so groups reflow onto new lines when the window narrows instead of overlapping. -->
        <WrapPanel Orientation="Horizontal" Margin="0,5,0,0">
            <WrapPanel.Styles>
                <!-- Uniform gap between groups; bottom gap shows when rows wrap. -->
                <Style Selector="WrapPanel > :is(Control)">
                    <Setter Property="Margin" Value="0,3,16,3"/>
                    <Setter Property="VerticalAlignment" Value="Center"/>
                </Style>
            </WrapPanel.Styles>

                <ComboBox ItemsSource="{Binding Status.AvailableModeDescriptions}" SelectedItem="{Binding Status.SelectedModeDescription}"
                          Background="Transparent" BorderThickness="0" Foreground="{DynamicResource SubTextForegroundBrush}"
                          FontSize="{DynamicResource SmallFontSize}" VerticalAlignment="Center" />

                    <!-- Connection picker: project connections (endpoint + model); switchable live -->
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <TextBlock Text="🔌" FontSize="{DynamicResource SmallFontSize}" VerticalAlignment="Center"
                                   ToolTip.Tip="Connection (endpoint + model)" />
                        <ComboBox ItemsSource="{Binding Connections}"
                                  SelectedItem="{Binding SelectedConnection}"
                                  MinWidth="120" Background="Transparent" BorderThickness="1"
                                  BorderBrush="{DynamicResource PanelBorderBrush}"
                                  Foreground="{DynamicResource SubTextForegroundBrush}"
                                  FontSize="{DynamicResource SmallFontSize}" VerticalAlignment="Center"
                                  ToolTip.Tip="Pick the connection this chat talks to">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <!-- Reasoning depth: toggle (off/on) or effort (low/medium/high), per the selected model -->
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center"
                                IsVisible="{Binding SelectedModelSupportsReasoning}">
                        <TextBlock Text="🧠" FontSize="{DynamicResource SmallFontSize}" VerticalAlignment="Center"
                                   ToolTip.Tip="Model reasoning depth" />
                        <ComboBox ItemsSource="{Binding SelectedModelReasoningOptions}"
                                  SelectedItem="{Binding ReasoningLevel}"
                                  MinWidth="80" Background="Transparent" BorderThickness="1"
                                  BorderBrush="{DynamicResource PanelBorderBrush}"
                                  Foreground="{DynamicResource SubTextForegroundBrush}"
                                  FontSize="{DynamicResource SmallFontSize}" VerticalAlignment="Center"
                                  ToolTip.Tip="off/on or reasoning effort (low/medium/high)" />
                    </StackPanel>

                    <!-- Temperature group -->
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <TextBlock Text="Temp" Foreground="{DynamicResource SubTextForegroundBrush}"
                                   FontSize="{DynamicResource SmallFontSize}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Temperature, StringFormat='{}{0:0.0}'}"
                                   Foreground="{DynamicResource SubTextForegroundBrush}"
                                   FontSize="{DynamicResource SmallFontSize}" Width="28"
                                   TextAlignment="Right" VerticalAlignment="Center" />
                        <Grid RowDefinitions="18,10" Width="260" Height="28" VerticalAlignment="Center">
                            <Slider Grid.Row="0" Minimum="0" Maximum="2" TickFrequency="0.1" IsSnapToTickEnabled="True"
                                    Value="{Binding Temperature}"
                                    Height="18" VerticalAlignment="Center"
                                    Margin="4,0" />
                            <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*,*" Margin="4,0">
                                <TextBlock Grid.Column="0" Text="Precise Code" Foreground="{DynamicResource SubTextForegroundBrush}"
                                           FontSize="8" VerticalAlignment="Top" />
                                <TextBlock Grid.Column="1" Text="Agent" Foreground="{DynamicResource SubTextForegroundBrush}"
                                           FontSize="8" TextAlignment="Center" VerticalAlignment="Top" />
                                <TextBlock Grid.Column="2" Text="Explore" Foreground="{DynamicResource SubTextForegroundBrush}"
                                           FontSize="8" TextAlignment="Center" VerticalAlignment="Top" />
                                <TextBlock Grid.Column="3" Text="Brainstorm" Foreground="{DynamicResource SubTextForegroundBrush}"
                                           FontSize="8" TextAlignment="Center" VerticalAlignment="Top" />
                                <TextBlock Grid.Column="4" Text="Experimental" Foreground="{DynamicResource SubTextForegroundBrush}"
                                           FontSize="8" TextAlignment="Right" VerticalAlignment="Top" />
                            </Grid>
                        </Grid>
                    </StackPanel>

                    <!-- Presence penalty -->
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center"
                                ToolTip.Tip="Presence penalty — 0 = off (default). Subtracts a fixed amount from any token the model already used (count=1 → X, count=5 → still X). Pushes toward new words and topics. Safe: 0.0–0.2. Above 0.3 the model may avoid needed terms, variable names, JSON keys. For code/JSON keep at 0.">
                        <TextBlock Text="P.pen" Foreground="{DynamicResource SubTextForegroundBrush}"
                                   FontSize="{DynamicResource SmallFontSize}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding PresencePenalty, StringFormat='{}{0:0.00}'}"
                                   Foreground="{DynamicResource SubTextForegroundBrush}"
                                   FontSize="{DynamicResource SmallFontSize}" Width="32"
                                   TextAlignment="Right" VerticalAlignment="Center" />
                        <Slider Minimum="0" Maximum="1.0" TickFrequency="0.05" IsSnapToTickEnabled="True"
                                Value="{Binding PresencePenalty}" Width="100" Height="18" VerticalAlignment="Center" Margin="2,0" />
                    </StackPanel>

                    <!-- Frequency penalty -->
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center"
                                ToolTip.Tip="Frequency penalty — 0 = off (default). Penalty grows with each repetition (count=1 → X, count=5 → 5X). Best against hard verbatim loops. Safe: 0.0–0.2. Above 0.3 code, JSON, technical terms start to break. Don't raise all three penalties at once.">
                        <TextBlock Text="F.pen" Foreground="{DynamicResource SubTextForegroundBrush}"
                                   FontSize="{DynamicResource SmallFontSize}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding FrequencyPenalty, StringFormat='{}{0:0.00}'}"
                                   Foreground="{DynamicResource SubTextForegroundBrush}"
                                   FontSize="{DynamicResource SmallFontSize}" Width="32"
                                   TextAlignment="Right" VerticalAlignment="Center" />
                        <Slider Minimum="0" Maximum="1.0" TickFrequency="0.05" IsSnapToTickEnabled="True"
                                Value="{Binding FrequencyPenalty}" Width="100" Height="18" VerticalAlignment="Center" Margin="2,0" />
                    </StackPanel>

                    <!-- Repeat penalty (llama.cpp / LM Studio) -->
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center"
                                ToolTip.Tip="Repeat penalty — 1.0 = off (default, llama.cpp / LM Studio). Multiplies down the logit of any token seen in the recent window. 1.05–1.1 = mild; 1.2+ = aggressive. Below 1.0 makes loops worse. Works independently of P.pen and F.pen — tune one at a time, never set all three high at once.">
                        <TextBlock Text="R.pen" Foreground="{DynamicResource SubTextForegroundBrush}"
                                   FontSize="{DynamicResource SmallFontSize}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding RepeatPenalty, StringFormat='{}{0:0.00}'}"
                                   Foreground="{DynamicResource SubTextForegroundBrush}"
                                   FontSize="{DynamicResource SmallFontSize}" Width="32"
                                   TextAlignment="Right" VerticalAlignment="Center" />
                        <Slider Minimum="1.0" Maximum="1.5" TickFrequency="0.05" IsSnapToTickEnabled="True"
                                Value="{Binding RepeatPenalty}" Width="100" Height="18" VerticalAlignment="Center" Margin="2,0" />
                    </StackPanel>

                    <!-- Display profile selector: data-driven from AvailableProfiles -->
                    <ItemsControl ItemsSource="{Binding AvailableProfiles}" VerticalAlignment="Center">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="2" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Classes="ProfileBtn"
                                        Classes.selected="{Binding IsSelected}"
                                        Content="{Binding DisplayName}"
                                        Command="{Binding $parent[UserControl].((chatvm:ChatSessionViewModel)DataContext).SelectProfileCommand}"
                                        CommandParameter="{Binding}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        <ItemsControl.Styles>
                            <Style Selector="Button.ProfileBtn">
                                <Setter Property="Padding" Value="8,3"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}"/>
                                <Setter Property="CornerRadius" Value="4"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="MinHeight" Value="22"/>
                                <Setter Property="Foreground" Value="{DynamicResource SubTextForegroundBrush}"/>
                                <Setter Property="FontSize" Value="{DynamicResource SmallFontSize}"/>
                            </Style>
                            <Style Selector="Button.ProfileBtn.selected">
                                <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Style>
                        </ItemsControl.Styles>
                    </ItemsControl>

                    <!-- Chat actions -->
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <Button Content="Compact" Command="{Binding CompactContextCommand}" Background="Transparent" Foreground="{DynamicResource SubTextForegroundBrush}" Cursor="Hand" ToolTip.Tip="Create summary and compact context" FontSize="{DynamicResource SmallFontSize}" Padding="{DynamicResource CompactMargin}" />
                        <Button Content="⎇ Fork" Command="{Binding ForkChatCommand}" Background="Transparent" Foreground="{DynamicResource SubTextForegroundBrush}" Cursor="Hand" ToolTip.Tip="Duplicate Chat" FontSize="{DynamicResource SmallFontSize}" Padding="{DynamicResource CompactMargin}" />
                    </StackPanel>
        </WrapPanel>
    </StackPanel>
</UserControl>

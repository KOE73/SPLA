<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:web="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.WebView"
             x:Class="SPLA.UI.Avalonia.Views.Chat.ChatWebView">

    <Border Margin="{DynamicResource StandardMargin}"
            Background="{DynamicResource AppBackgroundBrush}"
            BorderBrush="{DynamicResource PanelBorderBrush}"
            BorderThickness="1"
            CornerRadius="{DynamicResource StandardCornerRadius}">
        <web:NativeWebView x:Name="ChatBrowser" />
    </Border>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SPLA.UI.Avalonia.ViewModels"
             xmlns:chatvm="using:SPLA.UI.Avalonia.ViewModels.Chat"
             xmlns:views="clr-namespace:SPLA.UI.Avalonia.Views"
             x:Class="SPLA.UI.Avalonia.Views.Chat.ChatListView"
             x:DataType="vm:MainWindowViewModel">
    
    <Border Background="{DynamicResource PanelBackgroundBrush}" 
            BorderBrush="{DynamicResource PanelBorderBrush}" 
            BorderThickness="0,0,1,0">
        <Grid RowDefinitions="*,Auto">
            
            <!-- Projects / Sessions -->
            <Grid Grid.Row="0" RowDefinitions="Auto,*" Margin="{DynamicResource StandardMargin}">
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="{DynamicResource StandardSpacing}" VerticalAlignment="Center" Margin="0,0,0,10">
                    <TextBlock Text="Chats" FontSize="{DynamicResource HeaderFontSize}" FontWeight="Bold" Foreground="{DynamicResource TextForegroundBrush}" VerticalAlignment="Center" />
                    <Button Content="+ New" Command="{Binding NewChatCommand}" Background="{DynamicResource AccentBrush}" Foreground="White" FontWeight="Bold" Cursor="Hand" CornerRadius="{DynamicResource StandardCornerRadius}" Padding="10,5" FontSize="{DynamicResource SmallFontSize}" VerticalAlignment="Center"/>
                    <DropDownButton Content="Project"
                            Background="Transparent"
                            Foreground="{DynamicResource SubTextForegroundBrush}"
                            BorderBrush="{DynamicResource PanelBorderBrush}"
                            BorderThickness="1"
                            Cursor="Hand"
                            CornerRadius="{DynamicResource StandardCornerRadius}"
                            Padding="8,5"
                            FontSize="{DynamicResource SmallFontSize}"
                            VerticalAlignment="Center"
                            ToolTip.Tip="Create or open a SPLA project">
                        <DropDownButton.Flyout>
                            <Flyout Placement="Bottom">
                                <StackPanel MinWidth="150">
                                    <Button Content="New / Open Project..." 
                                            Command="{Binding CreateProjectCommand}" 
                                            Background="Transparent" 
                                            HorizontalAlignment="Stretch" 
                                            HorizontalContentAlignment="Left" />
                                    <Separator IsVisible="{Binding HasRecentProjects}" Margin="0,4" />
                                    <TextBlock Text="Recent Projects" 
                                               Foreground="{DynamicResource SubTextForegroundBrush}" 
                                               FontSize="11" 
                                               Margin="8,4" 
                                               IsVisible="{Binding HasRecentProjects}" />
                                    <ItemsControl ItemsSource="{Binding RecentProjects}" IsVisible="{Binding HasRecentProjects}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Content="{Binding Name}" 
                                                        Command="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).OpenRecentProjectCommand}" 
                                                        CommandParameter="{Binding}" 
                                                        Background="Transparent" 
                                                        HorizontalAlignment="Stretch" 
                                                        HorizontalContentAlignment="Left" 
                                                        ToolTip.Tip="{Binding Path}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Flyout>
                        </DropDownButton.Flyout>
                    </DropDownButton>
                </StackPanel>
                
                <ScrollViewer Grid.Row="1">
                    <ListBox ItemsSource="{Binding Chats}" SelectedItem="{Binding ActiveChat}" Background="Transparent" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="chatvm:ChatSessionViewModel">
                                <Grid ColumnDefinitions="Auto,*,Auto" Background="Transparent" Cursor="Hand">
                                    <!-- Per-chat state: "❓" waiting on user, "●" working -->
                                    <TextBlock Grid.Column="0" Text="{Binding StateGlyph}"
                                               Foreground="{DynamicResource AccentBrush}"
                                               FontSize="{DynamicResource BaseFontSize}"
                                               VerticalAlignment="Center" Margin="0,0,6,0"
                                               Width="14" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Classes="ChatTitle" Text="{Binding Title}" Foreground="{DynamicResource TextForegroundBrush}" FontWeight="Bold" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Classes="ChatDate" Text="{Binding Chat.UpdatedAt, StringFormat='{}{0:dd.MM HH:mm}'}" Foreground="{DynamicResource SubTextForegroundBrush}" />
                                    </StackPanel>
                                    <Button Classes="DeleteChatBtn" Grid.Column="2"
                                            Content="🗑"
                                            Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).DeleteChatCommand}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent"
                                            Foreground="{DynamicResource SubTextForegroundBrush}"
                                            BorderThickness="0"
                                            Padding="4,0"
                                            Cursor="Hand"
                                            ToolTip.Tip="Delete chat"
                                            VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="10,5"/>
                                <Setter Property="Margin" Value="0,2"/>
                                <Setter Property="CornerRadius" Value="{DynamicResource StandardCornerRadius}"/>
                            </Style>
                            <Style Selector="ListBoxItem TextBlock.ChatTitle">
                                <Setter Property="FontSize" Value="{DynamicResource BaseFontSize}"/>
                            </Style>
                            <Style Selector="ListBoxItem TextBlock.ChatDate">
                                <Setter Property="FontSize" Value="{DynamicResource SmallFontSize}"/>
                            </Style>
                            <Style Selector="ListBoxItem Button.DeleteChatBtn">
                                <Setter Property="FontSize" Value="{DynamicResource SmallFontSize}"/>
                            </Style>
                        </ListBox.Styles>
                    </ListBox>
                </ScrollViewer>
            </Grid>

            <!-- Recent Projects (Moved to dropdown menu) -->
            
        </Grid>
    </Border>
</UserControl>

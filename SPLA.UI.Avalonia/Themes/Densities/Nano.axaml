<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <!-- ========================================== -->
    <!-- Layout Spacing                             -->
    <!-- ========================================== -->
    <Thickness x:Key="StandardMargin">2</Thickness>
    <Thickness x:Key="StandardPadding">4</Thickness>
    <Thickness x:Key="CompactMargin">0</Thickness>
    <sys:Double x:Key="StandardSpacing">2</sys:Double>

    <!-- ========================================== -->
    <!-- Chat Bubble Layout                         -->
    <!-- ========================================== -->
    <Thickness x:Key="ChatBubbleMargin">2,1</Thickness>
    <Thickness x:Key="UserChatBubbleMargin">10,1,2,1</Thickness>
    <Thickness x:Key="AiChatBubbleMargin">2,1,10,1</Thickness>

    <!-- ========================================== -->
    <!-- Typography                                -->
    <!-- ========================================== -->
    <sys:Double x:Key="HeaderFontSize">16</sys:Double>
    <sys:Double x:Key="BaseFontSize">13</sys:Double>
    <sys:Double x:Key="SmallFontSize">11</sys:Double>

    <!-- ========================================== -->
    <!-- Shape                                      -->
    <!-- ========================================== -->
    <CornerRadius x:Key="StandardCornerRadius">2</CornerRadius>
</ResourceDictionary>

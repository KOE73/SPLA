<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- ========================================== -->
    <!-- Core Application Colors                    -->
    <!-- ========================================== -->
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F5F5F5" />
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="PanelBorderBrush" Color="#E0E0E0" />
    <SolidColorBrush x:Key="TextForegroundBrush" Color="#1E1E1E" />
    <SolidColorBrush x:Key="SubTextForegroundBrush" Color="#666666" />
    <SolidColorBrush x:Key="AccentBrush" Color="#007ACC" />

    <!-- ========================================== -->
    <!-- Chat & Bubble Colors                       -->
    <!-- ========================================== -->
    <SolidColorBrush x:Key="MessageBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="UserBubbleBackgroundBrush" Color="#EBF4FA" />
    <SolidColorBrush x:Key="AiBubbleBackgroundBrush" Color="#F2F2F2" />
    <SolidColorBrush x:Key="SystemBubbleBackgroundBrush" Color="#EAF2EB" />
    <SolidColorBrush x:Key="ToolBubbleBackgroundBrush" Color="#F3EBF5" />
    <SolidColorBrush x:Key="ErrorBubbleBackgroundBrush" Color="#FAEBEB" />

    <!-- ========================================== -->
    <!-- Input & Controls Colors                    -->
    <!-- ========================================== -->
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="InputBorderBrush" Color="#CCCCCC" />

    <!-- ========================================== -->
    <!-- ComboBox Override Colors                   -->
    <!-- ========================================== -->

    <!-- ComboBox styling overrides -->
    <SolidColorBrush x:Key="ComboBoxBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver" Color="#F0F0F0" />
    <SolidColorBrush x:Key="ComboBoxBackgroundFocused" Color="#F0F0F0" />
    <SolidColorBrush x:Key="ComboBoxBorderBrush" Color="#CCCCCC" />
    <SolidColorBrush x:Key="ComboBoxBorderBrushPointerOver" Color="#007ACC" />
    <SolidColorBrush x:Key="ComboBoxBorderBrushFocused" Color="#007ACC" />
    <SolidColorBrush x:Key="ComboBoxForeground" Color="#1E1E1E" />
    <SolidColorBrush x:Key="ComboBoxForegroundPointerOver" Color="#1E1E1E" />
    <SolidColorBrush x:Key="ComboBoxForegroundFocused" Color="#1E1E1E" />
    <SolidColorBrush x:Key="ComboBoxDropDownBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="ComboBoxDropdownBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="ComboBoxDropDownBorderBrush" Color="#E0E0E0" />
    <SolidColorBrush x:Key="ComboBoxDropdownBorderBrush" Color="#E0E0E0" />
    <SolidColorBrush x:Key="ComboBoxItemBackgroundPointerOver" Color="#007ACC" />
    <SolidColorBrush x:Key="ComboBoxItemBackgroundSelected" Color="#007ACC" />
    <SolidColorBrush x:Key="ComboBoxItemBackgroundSelectedPointerOver" Color="#007ACC" />
    <SolidColorBrush x:Key="ComboBoxItemForeground" Color="#1E1E1E" />
    <SolidColorBrush x:Key="ComboBoxItemForegroundPointerOver" Color="#FFFFFF" />
    <SolidColorBrush x:Key="ComboBoxItemForegroundSelected" Color="#FFFFFF" />
    <SolidColorBrush x:Key="ComboBoxItemForegroundSelectedPointerOver" Color="#FFFFFF" />
</ResourceDictionary>

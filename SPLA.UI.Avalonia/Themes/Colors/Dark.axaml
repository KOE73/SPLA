<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- ========================================== -->
    <!-- Core Application Colors                    -->
    <!-- ========================================== -->
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#1E1E1E" />
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#252526" />
    <SolidColorBrush x:Key="PanelBorderBrush" Color="#333333" />
    <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="#2F2F30" />
    <SolidColorBrush x:Key="CaptionHoverBrush" Color="#3C3C3C" />
    <SolidColorBrush x:Key="TextForegroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="SubTextForegroundBrush" Color="#888888" />
    <SolidColorBrush x:Key="AccentBrush" Color="#007ACC" />

    <!-- ========================================== -->
    <!-- Chat & Bubble Colors                       -->
    <!-- ========================================== -->
    <SolidColorBrush x:Key="MessageBackgroundBrush" Color="#333337" />
    <SolidColorBrush x:Key="UserBubbleBackgroundBrush" Color="#1E3A5F" />
    <SolidColorBrush x:Key="AiBubbleBackgroundBrush" Color="#2D2D30" />
    <SolidColorBrush x:Key="SystemBubbleBackgroundBrush" Color="#1A2D20" />
    <SolidColorBrush x:Key="ToolBubbleBackgroundBrush" Color="#2B1D36" />
    <SolidColorBrush x:Key="ErrorBubbleBackgroundBrush" Color="#3E1F1F" />

    <!-- ========================================== -->
    <!-- Input & Controls Colors                    -->
    <!-- ========================================== -->
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#252526" />
    <SolidColorBrush x:Key="InputBorderBrush" Color="#555555" />

    <!-- ========================================== -->
    <!-- ComboBox Override Colors                   -->
    <!-- ========================================== -->

    <!-- ComboBox styling overrides -->
    <SolidColorBrush x:Key="ComboBoxBackground" Color="#252526" />
    <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver" Color="#2D2D30" />
    <SolidColorBrush x:Key="ComboBoxBackgroundFocused" Color="#2D2D30" />
    <SolidColorBrush x:Key="ComboBoxBorderBrush" Color="#555555" />
    <SolidColorBrush x:Key="ComboBoxBorderBrushPointerOver" Color="#007ACC" />
    <SolidColorBrush x:Key="ComboBoxBorderBrushFocused" Color="#007ACC" />
    <SolidColorBrush x:Key="ComboBoxForeground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="ComboBoxForegroundPointerOver" Color="#FFFFFF" />
    <SolidColorBrush x:Key="ComboBoxForegroundFocused" Color="#FFFFFF" />
    <SolidColorBrush x:Key="ComboBoxDropDownBackground" Color="#252526" />
    <SolidColorBrush x:Key="ComboBoxDropdownBackground" Color="#252526" />
    <SolidColorBrush x:Key="ComboBoxDropDownBorderBrush" Color="#333333" />
    <SolidColorBrush x:Key="ComboBoxDropdownBorderBrush" Color="#333333" />
    <SolidColorBrush x:Key="ComboBoxItemBackgroundPointerOver" Color="#007ACC" />
    <SolidColorBrush x:Key="ComboBoxItemBackgroundSelected" Color="#007ACC" />
    <SolidColorBrush x:Key="ComboBoxItemBackgroundSelectedPointerOver" Color="#007ACC" />
    <SolidColorBrush x:Key="ComboBoxItemForeground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="ComboBoxItemForegroundPointerOver" Color="#FFFFFF" />
    <SolidColorBrush x:Key="ComboBoxItemForegroundSelected" Color="#FFFFFF" />
    <SolidColorBrush x:Key="ComboBoxItemForegroundSelectedPointerOver" Color="#FFFFFF" />
</ResourceDictionary>

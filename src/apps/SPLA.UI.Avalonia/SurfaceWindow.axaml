<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:web="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.WebView"
        x:Class="SPLA.UI.Avalonia.SurfaceWindow"
        Title="SPLA"
        Width="560" Height="680" MinWidth="320" MinHeight="240"
        WindowStartupLocation="CenterOwner"
        WindowDecorations="BorderOnly"
        ExtendClientAreaToDecorationsHint="True"
        Background="{DynamicResource AppBackgroundBrush}">

    <!-- A bare frame around one web surface (?surface=<name>). Avalonia is only the window manager;
         the content is the same web renderer the main window uses, mounted single. -->
    <Grid RowDefinitions="30,*">
        <DockPanel Grid.Row="0" Background="{DynamicResource TitleBarBackgroundBrush}">
            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="12,0,0,0" IsHitTestVisible="False">
                <TextBlock Text="SPLA" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource SubTextForegroundBrush}" VerticalAlignment="Center"/>
                <TextBlock x:Name="TitleText" Text="—" FontSize="12" Margin="6,0,0,0"
                           Foreground="{DynamicResource SubTextForegroundBrush}" Opacity="0.6" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Classes="caption" Content="⟳" Click="Reload_Click" ToolTip.Tip="Reload"/>
                <Button Classes="caption" Content="─" Click="Min_Click"/>
                <Button Classes="caption" Content="□" Click="Max_Click"/>
                <Button Classes="caption close" Content="✕" Click="Close_Click"/>
            </StackPanel>
            <Border Background="Transparent" PointerPressed="TitleBar_PointerPressed"/>
        </DockPanel>

        <web:NativeWebView x:Name="Browser" Grid.Row="1"/>
    </Grid>
</Window>

<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <!-- ========================================== -->
    <!-- Layout Spacing                             -->
    <!-- ========================================== -->
    <Thickness x:Key="StandardMargin">10</Thickness>
    <Thickness x:Key="StandardPadding">15</Thickness>
    <Thickness x:Key="CompactMargin">5</Thickness>
    <sys:Double x:Key="StandardSpacing">10</sys:Double>

    <!-- ========================================== -->
    <!-- Chat Bubble Layout                         -->
    <!-- ========================================== -->
    <Thickness x:Key="ChatBubbleMargin">10,3</Thickness>
    <Thickness x:Key="UserChatBubbleMargin">28,3,10,3</Thickness>
    <Thickness x:Key="AiChatBubbleMargin">10,3,28,3</Thickness>

    <!-- ========================================== -->
    <!-- Typography                                -->
    <!-- ========================================== -->
    <sys:Double x:Key="HeaderFontSize">18</sys:Double>
    <sys:Double x:Key="BaseFontSize">14</sys:Double>
    <sys:Double x:Key="SmallFontSize">12</sys:Double>
    <sys:Double x:Key="SidebarNodeFontSize">11</sys:Double>
    <sys:Double x:Key="SidebarIconFontSize">14</sys:Double>
    <sys:Double x:Key="SidebarToggleScale">0.84</sys:Double>

    <!-- ========================================== -->
    <!-- Shape                                      -->
    <!-- ========================================== -->
    <CornerRadius x:Key="StandardCornerRadius">8</CornerRadius>

    <!-- Single-line height of the message editor; Send button matches it. -->
    <sys:Double x:Key="InputBaseHeight">34</sys:Double>
</ResourceDictionary>

<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>SPLA.Plugins.OneC</RootNamespace>
    <AssemblyName>SPLA.Plugins.OneC</AssemblyName>
    <!-- Self-contained plugin: copy third-party NuGet deps (Microsoft.Data.Sqlite + native
         SQLitePCLRaw e_sqlite3) into the plugin folder so the PluginLoadContext resolver finds them
         under any host (CLI/service, not just Avalonia). -->
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\core\SPLA.MCP.Core\SPLA.MCP.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Data.Sqlite" Version="10.0.9" />
    <!--
      SQLITE_VULN_OVERRIDE (see docs/TODO_SQLITE_VULN.md).
      Microsoft.Data.Sqlite 10.0.9 still pulls SQLitePCLRaw 2.1.x, whose native
      SQLitePCLRaw.lib.e_sqlite3 is deprecated and flagged by GHSA-2m69-gcr7-jv3q
      (no fix on the 2.1 line). Override to the 3.0.x bundle, which swaps in
      SourceGear.sqlite3 (SQLite 3.50.4) and carries the fix.
    -->
    <PackageReference Include="SQLitePCLRaw.bundle_e_sqlite3" Version="3.0.3" />
  </ItemGroup>

  <ItemGroup>
    <!-- Embed the Cytoscape.js HTML viewer as an embedded resource -->
    <EmbeddedResource Include="Assets\onec_graph.html" />
    <!-- Prebuilt web browser module (web_settings_entry in meta.yaml). Landing it in TargetDir under
         web/dist means the CopyPlugin glob deploys it into each host's plugins/onec/web/dist — without
         this the served /plugin-assets URL 404s and the UI silently falls back to raw YAML. -->
    <None Include="Web\dist\**" CopyToOutputDirectory="PreserveNewest" Link="web\dist\%(RecursiveDir)%(Filename)%(Extension)" />
  </ItemGroup>

  <Target Name="CopyPlugin" AfterTargets="Build">
    <ItemGroup>
      <PluginFiles Include="$(TargetDir)**\*.*" />
      <MetaFile Include="meta.yaml" />
    </ItemGroup>
    <!-- Host apps live under src/apps (..\..\apps\<app>), NOT next to the plugins — the old ..\SPLA.CLI
         path silently deployed into a non-existent src/plugins/SPLA.CLI (see the same note in the SQL
         plugin csproj). -->
    <Copy SourceFiles="@(PluginFiles)" DestinationFolder="$(MSBuildThisFileDirectory)..\..\apps\SPLA.UI.Avalonia\bin\$(Configuration)\$(TargetFramework)\plugins\onec\%(RecursiveDir)" SkipUnchangedFiles="true" />
    <Copy SourceFiles="@(MetaFile)" DestinationFolder="$(MSBuildThisFileDirectory)..\..\apps\SPLA.UI.Avalonia\bin\$(Configuration)\$(TargetFramework)\plugins\onec\" SkipUnchangedFiles="true" />
    <Copy SourceFiles="@(PluginFiles)" DestinationFolder="$(MSBuildThisFileDirectory)..\..\apps\SPLA.CLI\bin\$(Configuration)\$(TargetFramework)\plugins\onec\%(RecursiveDir)" SkipUnchangedFiles="true" />
    <Copy SourceFiles="@(MetaFile)" DestinationFolder="$(MSBuildThisFileDirectory)..\..\apps\SPLA.CLI\bin\$(Configuration)\$(TargetFramework)\plugins\onec\" SkipUnchangedFiles="true" />
  </Target>

</Project>

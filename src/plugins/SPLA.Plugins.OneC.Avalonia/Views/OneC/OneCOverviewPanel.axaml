<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="SPLA.Plugins.OneC.Avalonia.Views.OneC.OneCOverviewPanel">
    <Grid RowDefinitions="*,Auto,Auto"
          ColumnDefinitions="360,*"
          ColumnSpacing="12"
          RowSpacing="12">
        <Border Grid.Row="0"
                Grid.Column="0"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12">
            <Grid RowDefinitions="Auto,Auto,*"
                  RowSpacing="8">
                <TextBox x:Name="SearchBox"
                         PlaceholderText="Поиск объекта 1С..." />
                <ListBox x:Name="SearchResultsList"
                         Grid.Row="1" />
                <TreeView x:Name="ObjectsTree"
                          Grid.Row="2" />
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Grid.Column="0"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12">
            <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*"
                  RowDefinitions="Auto,Auto"
                  ColumnSpacing="8"
                  RowSpacing="4">
                <TextBlock Text="Objects"
                           Foreground="{DynamicResource SubTextForegroundBrush}" />
                <TextBlock x:Name="ObjectsValueText"
                           Grid.Column="1"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextForegroundBrush}" />

                <TextBlock Grid.Column="2"
                           Text="Relations"
                           Foreground="{DynamicResource SubTextForegroundBrush}" />
                <TextBlock x:Name="RelationsValueText"
                           Grid.Column="3"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextForegroundBrush}" />

                <TextBlock Grid.Column="4"
                           Text="Sections"
                           Foreground="{DynamicResource SubTextForegroundBrush}" />
                <TextBlock x:Name="SectionsValueText"
                           Grid.Column="5"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextForegroundBrush}" />

                <TextBlock Grid.Row="1"
                           Text="Database"
                           Foreground="{DynamicResource SubTextForegroundBrush}" />
                <TextBlock x:Name="StatusTextBlock"
                           Grid.Row="1"
                           Grid.Column="1"
                           Grid.ColumnSpan="5"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource TextForegroundBrush}" />
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Grid.Column="0"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                  RowSpacing="8">
                <TextBlock Text="Context Export"
                           Foreground="{DynamicResource SubTextForegroundBrush}" />

                <Grid Grid.Row="1"
                      ColumnDefinitions="Auto,*"
                      ColumnSpacing="8">
                    <TextBlock Text="Context"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource SubTextForegroundBrush}" />
                    <ComboBox x:Name="FormatSelector"
                              Grid.Column="1"
                              MinWidth="120"
                              MaxWidth="220"
                              HorizontalAlignment="Left" />
                </Grid>

                <WrapPanel Grid.Row="2"
                           Orientation="Horizontal"
                           ItemSpacing="8"
                           LineSpacing="8">
                    <Button x:Name="CopyButton"
                            Content="Copy"
                            Background="{DynamicResource InputBackgroundBrush}"
                            Foreground="{DynamicResource TextForegroundBrush}"
                            BorderBrush="{DynamicResource PanelBorderBrush}"
                            BorderThickness="1"
                            Padding="12,6"
                            CornerRadius="8" />
                    <Button x:Name="InsertButton"
                            Content="Insert"
                            Background="{DynamicResource AccentBrush}"
                            Foreground="White"
                            Padding="12,6"
                            CornerRadius="8" />
                    <Button x:Name="RebuildIndexButton"
                            Content="Rebuild Index"
                            Background="{DynamicResource AccentBrush}"
                            Foreground="White"
                            Padding="12,6"
                            CornerRadius="8" />
                </WrapPanel>

                <TextBlock x:Name="IndexStatusTextBlock"
                           Grid.Row="3"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource SubTextForegroundBrush}" />
            </Grid>
        </Border>

        <Border Grid.Row="0"
                Grid.Column="1"
                Grid.RowSpan="3"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12">
            <Grid RowDefinitions="Auto,Auto,Auto,*"
                  RowSpacing="10">
                <TextBlock x:Name="ObjectTitleText"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextForegroundBrush}" />

                <WrapPanel Grid.Row="1"
                           Orientation="Horizontal"
                           ItemSpacing="8"
                           LineSpacing="8">
                    <Button x:Name="DependenciesButton"
                            Content="Dependencies Graph"
                            Background="{DynamicResource InputBackgroundBrush}"
                            Foreground="{DynamicResource TextForegroundBrush}"
                            BorderBrush="{DynamicResource PanelBorderBrush}"
                            BorderThickness="1"
                            Padding="12,6"
                            CornerRadius="8" />
                    <Button x:Name="ReferencesButton"
                            Content="References Graph"
                            Background="{DynamicResource InputBackgroundBrush}"
                            Foreground="{DynamicResource TextForegroundBrush}"
                            BorderBrush="{DynamicResource PanelBorderBrush}"
                            BorderThickness="1"
                            Padding="12,6"
                            CornerRadius="8" />
                    <Button x:Name="DataFlowButton"
                            Content="Data Flow Graph"
                            Background="{DynamicResource InputBackgroundBrush}"
                            Foreground="{DynamicResource TextForegroundBrush}"
                            BorderBrush="{DynamicResource PanelBorderBrush}"
                            BorderThickness="1"
                            Padding="12,6"
                            CornerRadius="8" />
                </WrapPanel>

                <TextBlock x:Name="GraphSummaryText"
                           Grid.Row="2"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource SubTextForegroundBrush}" />

                <Grid Grid.Row="3"
                      RowDefinitions="Auto,*"
                      RowSpacing="8">
                    <ScrollViewer MaxHeight="180"
                                  VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="ObjectDetailsText"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextForegroundBrush}" />
                    </ScrollViewer>

                    <NativeWebView x:Name="GraphWebView"
                                   Grid.Row="1" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>

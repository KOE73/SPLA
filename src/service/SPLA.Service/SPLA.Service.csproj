<Project Sdk="Microsoft.NET.Sdk">

  <!--
    The SPLA service host: wraps the agent core (same stack the CLI builds) behind a WebSocket
    protocol so any client — the Avalonia thin client, a browser, a phone — drives one agent the
    same way, whether it is in-process (embedded) or across the network (remote).
  -->

  <PropertyGroup>
    <!-- Minimal ASP.NET host for the WebSocket endpoint + static web client assets later. -->
    <UseAspNet>true</UseAspNet>
  </PropertyGroup>

  <ItemGroup Condition="'$(UseAspNet)' == 'true'">
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
    <!-- Negotiate (NTLM/Kerberos) auth for the server host. Not in the shared framework — a separate
         package. Only enforced when ServiceOptions.RequireAuthentication is set (the SPLA.Server host);
         loopback/embedded stays auth-free. -->
    <PackageReference Include="Microsoft.AspNetCore.Authentication.Negotiate" Version="10.0.0" />
  </ItemGroup>

  <!-- OTLP export (Grafana/Tempo/Jaeger/Datadog/…). Only active when an OTLP endpoint is configured;
       ships out the same "SPLA" meter/traces the local stats collector taps in-process. -->
  <ItemGroup>
    <PackageReference Include="OpenTelemetry.Extensions.Hosting" Version="1.16.0" />
    <PackageReference Include="OpenTelemetry.Exporter.OpenTelemetryProtocol" Version="1.16.0" />
  </ItemGroup>

  <!-- The browser client (web/, Vue 3 + TS + Vite) builds to web/dist before each build, then
       ships embedded — the service stays self-contained with no content-root/wwwroot wiring at
       runtime. LogicalName is set explicitly so it still resolves to "SPLA.Service.WebClient.*",
       matching WebAssets.cs — files outside the project cone otherwise lose their directory path. -->
  <Target Name="BuildWebClient" BeforeTargets="BeforeBuild" Condition="Exists('$(MSBuildThisFileDirectory)..\..\..\web\package.json')">
    <Exec Command="npm install" WorkingDirectory="$(MSBuildThisFileDirectory)..\..\..\web" Condition="!Exists('$(MSBuildThisFileDirectory)..\..\..\web\node_modules')" />
    <Exec Command="npm run build" WorkingDirectory="$(MSBuildThisFileDirectory)..\..\..\web" />
  </Target>

  <!-- Glob the embedded resources INSIDE a target that runs after the web build, not as a static
       ItemGroup. A static glob is evaluated at project-load time and captures the PREVIOUS build's
       hashed filenames (index-<hash>.js/css); BuildWebClient then regenerates dist with NEW hashes,
       so the compiler was handed items pointing at files that no longer exist — the first
       `dotnet build` after editing any web source failed with CS1566 ("could not find
       index-<hash>.css") and only a second run, re-evaluated against the fresh dist, succeeded.
       Running the glob at BeforeCompile (after BuildWebClient) always sees the just-produced files. -->
  <!-- Single hook (BeforeTargets="CoreCompile") + DependsOnTargets="BuildWebClient" so the target
       runs exactly ONCE, after the web build and before compile. Hooking both AfterTargets and
       BeforeTargets makes MSBuild execute the body at BOTH injection points, adding the same items
       twice → CS1508 (duplicate resource identifier). -->
  <Target Name="EmbedWebClient" BeforeTargets="CoreCompile" DependsOnTargets="BuildWebClient"
          Condition="Exists('$(MSBuildThisFileDirectory)..\..\..\web\dist')">
    <ItemGroup>
      <EmbeddedResource Include="..\..\..\web\dist\**\*.*">
        <LogicalName>SPLA.Service.WebClient.$([System.String]::new('%(RecursiveDir)%(Filename)%(Extension)').Replace('\', '.'))</LogicalName>
      </EmbeddedResource>
    </ItemGroup>
  </Target>

  <ItemGroup>
    <ProjectReference Include="..\..\service\SPLA.Service.Contracts\SPLA.Service.Contracts.csproj" />
    <ProjectReference Include="..\..\agent\SPLA.Agent\SPLA.Agent.csproj" />
    <ProjectReference Include="..\..\agent\SPLA.Runtime\SPLA.Runtime.csproj" />
    <ProjectReference Include="..\..\core\SPLA.Domain\SPLA.Domain.csproj" />
    <ProjectReference Include="..\..\llm\SPLA.LLM.LMStudio\SPLA.LLM.LMStudio.csproj" />
    <ProjectReference Include="..\..\agent\SPLA.MCP.BasicTools\SPLA.MCP.BasicTools.csproj" />
    <ProjectReference Include="..\..\core\SPLA.MCP.Core\SPLA.MCP.Core.csproj" />
    <ProjectReference Include="..\..\core\SPLA.Observability\SPLA.Observability.csproj" />
    <!-- SSH mechanics for the live xterm terminal bridge (phase B), shared with the SSH plugin. -->
    <ProjectReference Include="..\..\core\SPLA.Ssh.Core\SPLA.Ssh.Core.csproj" />
  </ItemGroup>

</Project>
